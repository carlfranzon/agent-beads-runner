#!/usr/bin/env bash
set -euo pipefail

#
# abr — Agent Beads Runner
# Portable parallel AI agent launcher using git worktrees + beads
#
# Run from any beads-enabled git repo. Modes compose:
# --loop keeps respawning, --parallel-N adds tmux panes.
# Each bead always gets a completely fresh agent session.
#
# Usage:
#   abr                                  # Launch orchestrator + 4 idle worker panes (default)
#   abr --no-tui                         # One agent, one bead, exits (skip orchestrator)
#   abr --loop                           # Keeps picking beads sequentially until none left
#   abr --loop-5                         # Loop through at most 5 beads, then stop
#   abr --parallel-3                     # 3 agents in tmux, each works one bead
#   abr --loop --parallel-3              # 3 tmux panes, each loops until no beads left
#   abr --review                         # Review all open agent PRs
#   abr --review --pr 5                  # Review a specific PR
#   abr --review --parallel-3            # Review PRs in 3 parallel tmux panes
#   abr --prune-local-branches           # Delete merged local agent/* branches
#   abr --prune-remote-branches          # Delete merged remote agent/* branches
#   abr --no-tui --bead <id>             # Work a specific bead (without orchestrator)
#   abr --agent gemini                   # Use Gemini CLI (default: copilot)
#   abr --agent copilot --model opus46-h # Use Copilot with Opus 4.6, high effort
#   abr --dry-run                        # Show what would happen
#

ABR_VERSION="0.3.0"

# --- Early-exit commands (no git repo required) -------------------------------

# Handle --version, --help, --install-skill, and setup flags before anything else
_early_setup_agent=""
_early_setup_model=""

args=("$@")
for ((i=0; i<${#args[@]}; i++)); do
    case "${args[i]}" in
        --version|-V) echo "abr $ABR_VERSION"; exit 0 ;;
        --install-skill) INSTALL_SKILL=true ;;
        --set-default-agent)
            _early_setup_agent="${args[i+1]:-}"
            ;;
        --set-default-model)
            _early_setup_model="${args[i+1]:-}"
            ;;
    esac
done

if [[ "${INSTALL_SKILL:-}" == "true" ]]; then
    install_skill() {
        local platforms=()
        local dirs=()

        echo "abr — Install AI agent skill"
        echo ""
        echo "Select platforms to install the abr skill to:"
        echo ""
        echo "  1) GitHub Copilot   ~/.copilot/skills/abr/"
        echo "  2) Claude Code      ~/.claude/skills/abr/"
        echo "  3) Gemini           ~/.gemini/extensions/abr/"
        echo "  4) Codex            ~/.codex/skills/abr/"
        echo "  5) Generic agents   ~/.agents/skills/abr/"
        echo "  6) All of the above"
        echo ""
        printf "Enter choices (comma-separated, e.g. 1,2,3): "
        read -r choices

        if [[ -z "$choices" ]]; then
            echo "No selection made. Exiting."
            exit 0
        fi

        # Parse choices
        IFS=',' read -ra picks <<< "$choices"
        for pick in "${picks[@]}"; do
            pick=$(echo "$pick" | tr -d ' ')
            case "$pick" in
                1) platforms+=("GitHub Copilot");  dirs+=("$HOME/.copilot/skills/abr") ;;
                2) platforms+=("Claude Code");     dirs+=("$HOME/.claude/skills/abr") ;;
                3) platforms+=("Gemini");          dirs+=("$HOME/.gemini/extensions/abr") ;;
                4) platforms+=("Codex");           dirs+=("$HOME/.codex/skills/abr") ;;
                5) platforms+=("Generic agents");  dirs+=("$HOME/.agents/skills/abr") ;;
                6)
                    platforms=("GitHub Copilot" "Claude Code" "Gemini" "Codex" "Generic agents")
                    dirs=("$HOME/.copilot/skills/abr" "$HOME/.claude/skills/abr" "$HOME/.gemini/extensions/abr" "$HOME/.codex/skills/abr" "$HOME/.agents/skills/abr")
                    break
                    ;;
                *) echo "Unknown choice: $pick (skipping)" ;;
            esac
        done

        if [[ ${#dirs[@]} -eq 0 ]]; then
            echo "No valid platforms selected. Exiting."
            exit 0
        fi

        echo ""
        for i in "${!dirs[@]}"; do
            local dir="${dirs[$i]}"
            local name="${platforms[$i]}"
            mkdir -p "$dir"
            cat > "$dir/SKILL.md" <<'SKILL_CONTENT'
---
name: abr
description: 'Launch parallel AI coding agents with abr (Agent Beads Runner). Use when: running agents on beads, launching parallel agents, starting agent loops, reviewing agent PRs, configuring agent models, using abr CLI, spawning tmux agent panes, managing worktrees for agents.'
argument-hint: 'Describe what you want to do, e.g. "launch 3 agents on ready beads" or "review open PRs with Gemini"'
---

# Agent Beads Runner (abr)

`abr` launches AI coding agents in isolated git worktrees to work on beads tasks. Each agent gets a fresh worktree, works one bead, creates a PR, and cleans up.

## Prerequisites

- `abr` installed (`brew tap carlfranzon/tap && brew install abr`)
- `bd` CLI installed and initialized in the repo (`bd init`)
- At least one agent CLI installed: `copilot`, `claude`, `gemini`, or `codex`
- `git`, `python3`, `gh` (GitHub CLI) available
- `tmux` required for `--parallel` mode
- `gum` for interactive C&C selectors and slash workflows

## Quick Reference

| Goal | Command |
|------|---------|
| Launch orchestrator (default) | `abr` |
| Work one bead, exit | `abr --no-tui` |
| Work a specific bead | `abr --no-tui --bead <id>` |
| Loop until no beads left | `abr --loop` |
| Loop through at most 5 beads | `abr --loop-5` |
| 3 parallel agents | `abr --parallel-3` |
| 3 parallel agents, each looping | `abr --loop --parallel-3` |
| Run one bead from C&C (slash) | `/go` |
| Interactive launch wizard (slash) | `/start` |
| Set default agent (slash) | `/agent` |
| Set default model (slash) | `/model` |
| Show bead board (slash) | `/beads` |
| Bead action menu (slash) | `/bead` |
| Prune merged branches (slash) | `/prune` |
| Review open agent PRs (slash) | `/review` |
| Slash help | `/help` |
| Shutdown orchestrator session (slash) | `/exit` or `/quit` |
| Review all open agent PRs | `abr --review` |
| Review a specific PR | `abr --review --pr 5` |
| Review PRs in parallel | `abr --review --parallel-3` |
| Delete merged local branches | `abr --prune-local-branches` |
| Delete merged remote branches | `abr --prune-remote-branches` |
| Use a different agent | `abr --agent claude` |
| Use a specific model | `abr --agent copilot --model sonnet-46-h` |
| Preview without executing | `abr --dry-run` |
| Install skill for AI agents | `abr --install-skill` |
| Setup default agent | `abr --set-default-agent <tool>` |
| Setup default model | `abr --set-default-model <model>` |

## Agents

Four agent backends are supported via `--agent`:

| Agent | CLI | Default Model |
|-------|-----|---------------|
| `copilot` (default) | `copilot` | `claude-sonnet-4.6` (high effort) |
| `claude` | `claude` | `claude-sonnet-4-6` |
| `gemini` | `gemini` | `gemini-2.5-pro` |
| `codex` | `codex` | `gpt-5.4` |

## Model Selection

Use `--model <short-name>` with optional effort suffix.

### Short Names (most common)

| Short Name | Copilot Model | Claude Model |
|------------|---------------|--------------|
| `sonnet46` or `sonnet-46` | `claude-sonnet-4.6` | `claude-sonnet-4-6` |
| `sonnet45` or `sonnet-45` | `claude-sonnet-4.5` | `claude-sonnet-4-5` |
| `opus46` or `opus-46` | `claude-opus-4.6` | `claude-opus-4-6` |
| `opus45` or `opus-45` | `claude-opus-4.5` | `claude-opus-4-5` |
| `gpt54` or `gpt-54` | `gpt-5.4` | — |
| `gem25p` or `gem-25p` | `gemini-2.5-pro` | — |

### Effort Suffixes

Append `-l`, `-m`, `-h`, or `-xh` to any short name:

| Suffix | Meaning | Example |
|--------|---------|---------|
| `-l` | low | `sonnet46-l` |
| `-m` | medium | `gpt54-m` |
| `-h` | high | `sonnet-46-h` |
| `-xh` | extra-high | `gpt52-xh` |

Effort is passed via `--effort` for Copilot, `-c model_reasoning_effort` for Codex. Claude and Gemini parse but ignore effort (no CLI flag).

## Workflow of a Single Agent Run

1. `abr` picks the next ready bead (or uses `--bead <id>`)
2. Claims the bead (`bd update <id> --claim`) and pushes claim
3. Creates an isolated git worktree on a new branch (`agent/<bead-id>`)
4. Copies `.env*` files and installs dependencies
5. Launches the agent with a structured prompt
6. Agent implements changes, runs quality gates, commits, and pushes
7. `abr` creates a PR via `gh`
8. Worktree and local branch are cleaned up

## Branch Maintenance

- Delete merged local `agent/*` branches with `abr --prune-local-branches`
- Delete merged remote `agent/*` branches (and stale remote refs) with `abr --prune-remote-branches`

## Graceful Stop (Loop Mode)

- Press `Ctrl+C` once to finish the current bead and stop
- From another terminal: `touch <repo-root>/.agent-stop`
- Send signal: `kill -USR1 <pid>`

## Tmux Session Management

- Sessions are named `abr-<repo-name>` by default
- New `--parallel` panes are added to existing sessions
- Use `--new-tmux` to create a separate session
- Override name with `TMUX_SESSION=<name>` env var

## Config Files

Users can set defaults interactively via `abr --set-default-agent <tool>` and `abr --set-default-model <model>`. You can save these to your workspace (`.abr.conf`) or globally (`~/.config/abr/config`). Override global location with `ABR_CONFIG` env var.

```
agent = claude
model = sonnet46-h
```

Precedence: `--flag` > env var > workspace config > global config > built-in default.

| Key | Default | Purpose |
|-----|---------|---------|
| `agent` | `copilot` | Default agent backend |
| `model` | *(per-agent)* | Default model short name |
| `copilot_cli` | `copilot` | Path to Copilot CLI binary |
| `tmux_session` | `abr-<repo>` | tmux session name |

## Environment Variables

| Variable | Default | Purpose |
|----------|---------|---------|
| `AGENT_TOOL` | `copilot` | Default agent backend (overrides config file) |
| `COPILOT_CLI` | `copilot` | Path to Copilot CLI binary |
| `TMUX_SESSION` | `abr-<repo>` | tmux session name |
| `ABR_CONFIG` | `~/.config/abr/config` | Path to config file |

## Procedure

When the user wants to launch agents:

1. Verify prerequisites: `command -v abr bd git gh tmux`
2. Ensure beads are initialized: `bd ready` should list beads
3. Construct the `abr` command from the quick reference table above
4. If unsure, use `--dry-run` first to preview
5. Run the command
6. For parallel mode, attach to tmux: `tmux attach -t abr-<repo-name>`
7. Monitor progress in tmux panes; agents auto-clean up when done

SKILL_CONTENT
            echo "  ✓ Installed to $dir ($name)"
        done

        echo ""
        echo "Done! Your AI agents will now discover the abr skill automatically."
    }

    install_skill
    exit 0
fi

if [[ -n "$_early_setup_agent" ]] || [[ -n "$_early_setup_model" ]]; then
    set_defaults() {
        echo "abr — Set Default Configuration"
        echo ""
        
        local target="global"
        local repo_root=""
        
        if repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
            echo "Where do you want to save these settings?"
            echo "  1) Current workspace ($repo_root/.abr.conf)"
            echo "  2) Globally (~/.config/abr/config)"
            printf "Enter choice (1 or 2, default 1): "
            read -r choice
            if [[ "$choice" == "2" ]]; then
                target="global"
            else
                target="workspace"
            fi
        else
            echo "Not inside a git repository, saving globally."
            target="global"
        fi
        
        local conf_file=""
        if [[ "$target" == "global" ]]; then
            conf_file="${XDG_CONFIG_HOME:-$HOME/.config}/abr/config"
            mkdir -p "$(dirname "$conf_file")"
        else
            conf_file="$repo_root/.abr.conf"
        fi
        
        touch "$conf_file"
        
        if [[ -n "$_early_setup_agent" ]]; then
            grep -v "^agent[[:space:]]*=" "$conf_file" > "${conf_file}.tmp" || true
            echo "agent = ${_early_setup_agent}" >> "${conf_file}.tmp"
            mv "${conf_file}.tmp" "$conf_file"
            echo "✓ Set default agent to: ${_early_setup_agent} (in $conf_file)"
        fi
        
        if [[ -n "$_early_setup_model" ]]; then
            grep -v "^model[[:space:]]*=" "$conf_file" > "${conf_file}.tmp" || true
            echo "model = ${_early_setup_model}" >> "${conf_file}.tmp"
            mv "${conf_file}.tmp" "$conf_file"
            echo "✓ Set default model to: ${_early_setup_model} (in $conf_file)"
        fi
        
        echo ""
        echo "Done!"
    }
    
    set_defaults
    exit 0
fi

# --- Configuration -----------------------------------------------------------

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || {
    echo "Error: Not inside a git repository." >&2; exit 1
}
REPO_NAME="$(basename "$REPO_ROOT")"
WORKTREE_BASE="${REPO_ROOT}-worktrees"

# Load config file: ~/.config/abr/config (override with ABR_CONFIG env var)
# Also check workspace config (.abr.conf) which overrides global settings.
# Config sets defaults; env vars override config; --flags override everything.
# Supported keys: agent, model, copilot_cli, tmux_session
ABR_CONFIG="${ABR_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/abr/config}"
_cfg_agent="" _cfg_model="" _cfg_copilot_cli="" _cfg_tmux_session=""

for cfg_file in "$ABR_CONFIG" "${REPO_ROOT}/.abr.conf"; do
    if [[ -f "$cfg_file" ]]; then
        while IFS='=' read -r key value || [[ -n "$key" ]]; do
            # Skip comments and blank lines
            key="${key%%#*}"
            key="$(echo "$key" | tr -d '[:space:]')"
            [[ -z "$key" ]] && continue
            # Strip optional surrounding quotes from value
            value="${value#"${value%%[![:space:]]*}"}"   # trim leading whitespace
            value="${value%"${value##*[![:space:]]}"}"   # trim trailing whitespace
            value="${value#\"}" ; value="${value%\"}"
            value="${value#\'}" ; value="${value%\'}"
            case "$key" in
                agent)        _cfg_agent="$value" ;;
                model)        _cfg_model="$value" ;;
                copilot_cli)  _cfg_copilot_cli="$value" ;;
                tmux_session) _cfg_tmux_session="$value" ;;
            esac
        done < "$cfg_file"
    fi
done

# Precedence: env var > config file > built-in default
COPILOT_CLI="${COPILOT_CLI:-${_cfg_copilot_cli:-copilot}}"
PARALLEL=0        # 0 = no tmux; N = number of tmux panes
LOOP_MODE=false
LOOP_MAX=0        # 0 = unlimited; N = stop after N beads
REVIEW_MODE=false
ORCHESTRATOR_MODE=false
NO_TUI=false
DRY_RUN=false
NEW_TMUX=false
PRUNE_LOCAL_BRANCHES=false
PRUNE_REMOTE_BRANCHES=false
TARGET_BEAD=""
TARGET_PR=""      # PR number for --review --pr <N>
REVIEW_SUMMARY_FILE=""  # Temp file for accumulating review run summary (set by run_review)
INTERNAL_ORCHESTRATOR=""  # Non-empty = run_orchestrator mode; value = num_workers
INTERNAL_CC=""           # Non-empty = run_cc (command & control) mode; value = num_workers
INTERNAL_BEADS_BOARD="" # Non-empty = write beads board to log then exit; value = log path
AGENT_TOOL="${AGENT_TOOL:-${_cfg_agent:-copilot}}"  # copilot | claude | gemini | codex
MODEL="${_cfg_model:-}"  # Model short name (e.g. sonnet46-h); empty = agent default
TMUX_SESSION="${TMUX_SESSION:-${_cfg_tmux_session:-abr-${REPO_NAME}}}"
GUM_AVAILABLE=false

# --- Parse arguments ----------------------------------------------------------

while [[ $# -gt 0 ]]; do
    case "$1" in
        --loop)         LOOP_MODE=true; shift ;;
        --loop-[0-9]*)
            LOOP_MODE=true
            LOOP_MAX="${1#--loop-}"
            if [[ "$LOOP_MAX" -lt 1 ]]; then
                echo "Loop count must be >= 1" >&2; exit 1
            fi
            shift ;;
        --review)       REVIEW_MODE=true; shift ;;
        --no-tui)       NO_TUI=true; shift ;;
        --orchestrator) ORCHESTRATOR_MODE=true; PARALLEL=4; NEW_TMUX=true; shift ;;
        --dry-run)      DRY_RUN=true; shift ;;
        --new-tmux)     NEW_TMUX=true; shift ;;
        --prune-local-branches) PRUNE_LOCAL_BRANCHES=true; shift ;;
        --prune-remote-branches) PRUNE_REMOTE_BRANCHES=true; shift ;;
        --bead)         TARGET_BEAD="$2"; shift 2 ;;
        --pr)           TARGET_PR="$2"; shift 2 ;;
        --agent)        AGENT_TOOL="$2"; shift 2 ;;
        --install-skill) shift ;;  # already handled above
        --model)        MODEL="$2"; shift 2 ;;
        --internal-orchestrator) INTERNAL_ORCHESTRATOR="$2"; shift 2 ;;
        --internal-cc) INTERNAL_CC="$2"; shift 2 ;;
        --internal-beads-board) INTERNAL_BEADS_BOARD="$2"; shift 2 ;;
        --parallel-[0-9]*)
            PARALLEL="${1#--parallel-}"
            if [[ "$PARALLEL" -lt 1 ]]; then
                echo "Parallel count must be >= 1" >&2; exit 1
            fi
            shift ;;
        --parallel)
            PARALLEL=3; shift ;;
        --version|-V)
            echo "abr $ABR_VERSION"; exit 0 ;;
        -h|--help)
            cat <<'HELP'
abr — Agent Beads Runner
Portable parallel AI agent launcher using git worktrees + beads

Usage:
  abr                                    Launch orchestrator + 4 idle worker panes (default)
  abr --no-tui                           One agent, one bead, exits (skip orchestrator)
  abr --loop                             Keeps picking beads sequentially until none left
  abr --loop-5                           Loop through at most 5 beads, then stop
  abr --parallel-3                       3 agents in tmux panes, each works one bead
  abr --loop --parallel-3                3 tmux panes, each keeps looping until no beads left
  abr --bead <id>                        Work a specific bead
  abr --review                           Review all open agent PRs
  abr --review --pr 5                    Review a specific PR
  abr --review --parallel-3              Review PRs in 3 parallel tmux panes
  abr --no-tui                           Skip orchestrator TUI, run one bead then exit
  abr --orchestrator                     Launch orchestrator + 4 idle worker panes (explicit)
  abr --prune-local-branches             Delete merged local agent/* branches
  abr --prune-remote-branches            Delete merged remote agent/* branches
  abr --agent gemini                     Use Gemini CLI
  abr --agent copilot --model opus46-h   Use Copilot with Opus 4.6, high effort
  abr --install-skill                    Install abr skill for AI agents
  abr --set-default-agent gemini         Interactively configure the default agent
  abr --set-default-model gem31p         Interactively configure the default model
  abr --dry-run                          Preview without executing

Graceful stop (loop mode):
  Press Ctrl+C once during a loop to finish the current bead and stop.
  Or: touch $REPO_ROOT/.agent-stop   (from another terminal)
  Or: kill -USR1 <pid>               (sends stop signal to the loop)
  Or (C&C): stop --target A<n>       (per-agent graceful stop from C&C prompt)

Orchestrator dashboard & C&C prompt (parallel mode):
  When --parallel-N is used, a central orchestrator pane sits between the
  agent columns showing live colour-coded events.  The bottom 4 lines of the
  orchestrator are a dedicated Command & Control (C&C) prompt (abr> ).

    abr> /go                 Run a single agent on the next ready bead
    abr> /start              Interactive launch wizard
    abr> /agent              Select and persist default agent
    abr> /model              Select and persist default model
    abr> /beads              Show bead status board grouped by status
    abr> /bead               Select one bead, then choose an action
    abr> /prune              Prune merged branches (local, remote, or both)
    abr> /review             Run a single review agent on open agent PRs
    abr> /help               Print slash-command reference in dashboard
    abr> /exit or /quit      Kill the whole tmux session and return to terminal

    Legacy commands still supported:
    abr> run  --target A1 [--agent X] [--model Y] [extra-abr-flags]
             Respawn the agent in pane A1 via tmux respawn-pane -k.
             Defaults to --loop; any extra abr flags are forwarded.
  abr> stop  --target A2
             Graceful stop — worker finishes its current bead, then exits.
  abr> kill  --target A3
             Hard-kill the pane; layout grid is preserved (respawn placeholder).
  abr> status
             Print a pane-alias → tmux-pane-ID liveness table in the dashboard.
  abr> help  Print command reference in the dashboard (scrolls in large pane).
    abr> exit/quit
                         Kill the whole tmux session (all panes) and return to terminal.

  Pane aliases: A1 = first worker, A2 = second, etc. (assigned in launch order)
  Alias → pane-ID map is stored in <worktree-base>/.abr-ipc/pane-A<n>.

Options:
  --loop                Keep respawning agents until no ready beads remain
  --loop-N              Loop through at most N beads then stop (e.g. --loop-5)
  --parallel-N          Run N agents in tmux panes (e.g. --parallel-5)
  --parallel            Shorthand for --parallel-3
  --bead <id>           Work on a specific bead instead of auto-picking
  --review              Review open agent-created PRs (merge, reject, or file follow-up beads)
  --pr <number>         With --review: review a specific PR number
  --no-tui              Skip orchestrator TUI; run plain mode (one bead, or with --loop/--parallel)
  --orchestrator        Start a dedicated orchestrator tmux session with 4 idle worker panes (explicit)
  --prune-local-branches Delete merged local agent/* branches
  --prune-remote-branches Delete merged remote agent/* branches and stale remote refs
  --agent <tool>        AI tool: copilot (default), claude, gemini, codex
  --model <name>        Model short name (see table below). Default: per-agent
  --new-tmux            Create a separate tmux session (default: add panes to existing)
  --install-skill       Install abr skill to AI agent platforms (interactive)
  --set-default-agent   Configures your default agent interactively
  --set-default-model   Configures your default model interactively
  --dry-run             Show what would happen without executing
  --version, -V         Show version
  -h, --help            Show this help

Modes compose:
  (default)             Orchestrator TUI + 4 idle worker panes (use /start or /go from C&C)
  --no-tui              One agent → one bead → exit
  --loop / --loop-N     Fresh session per bead → pick next → repeat → exit when none left (or after N)
  --parallel-N          N tmux panes → each works one bead → all exit
  --loop --parallel-N   N tmux panes → each loops (fresh session per bead) → exit when none left
  --review              Review agent PRs → run quality gates → AI verdict → merge or reject

tmux behavior:
  If a tmux session already exists for this repo, new --parallel panes are added
  to it. Use --new-tmux to create a separate session (e.g. for a different agent).

Config files:
  Run `abr --set-default-agent <tool>` or `abr --set-default-model <model>`
  to interactively save defaults to your workspace (.abr.conf) or globally 
  (~/.config/abr/config).
  Override global location with ABR_CONFIG env var.
  Precedence: --flag > env var > workspace config > global config > built-in.

  Example ~/.config/abr/config or .abr.conf:
    agent = claude
    model = sonnet46-h

  Supported keys:
    agent          Default agent backend (copilot, claude, gemini, codex)
    model          Default model short name (e.g. sonnet46-h)
    copilot_cli    Path to Copilot CLI binary
    tmux_session   tmux session name

Models (--model <name>):
  Use short names from the table, or pass a full model name directly.
  Unrecognized short names are passed through as-is to the agent CLI.

  Effort/reasoning suffixes:
    Append -l (low), -m (medium), -h (high), or -xh (extra-high) to any
    short name to set reasoning effort.  Example: --model sonnet46-h
    Copilot: passed via --effort flag. Codex: passed via -c model_reasoning_effort.
    Claude and Gemini: suffix is parsed but has no effect (no CLI flag).

  Copilot (--agent copilot)              default: sonnet46-h
    Effort: --effort flag works with ALL models (low/medium/high/xhigh)
    Short Name     Model                    Reasoning
    ─────────────  ─────────────────────    ─────────
    sonnet46       claude-sonnet-4.6        extended thinking
    sonnet45       claude-sonnet-4.5        extended thinking
    sonnet4        claude-sonnet-4          no
    opus46         claude-opus-4.6          extended thinking
    opus45         claude-opus-4.5          extended thinking
    haiku          claude-haiku-4.5         no
    gpt41          gpt-4.1                  no
    gpt5m          gpt-5-mini              effort (l/m/h/xh)
    gpt52          gpt-5.2                  effort (l/m/h/xh)
    gpt52c         gpt-5.2-codex            effort (l/m/h/xh)
    gpt53c         gpt-5.3-codex            effort (l/m/h/xh)
    gpt54          gpt-5.4                  effort (l/m/h/xh)
    gpt54m         gpt-5.4-mini             effort (l/m/h/xh)
    gem25p         gemini-2.5-pro           thinking
    gem3f          gemini-3-flash-preview   no
    gem31p         gemini-3.1-pro-preview   no
    grok           grok-code-fast-1         no
    raptor         raptor-mini              no
    goldeneye      goldeneye                no

  Claude (--agent claude)                default: sonnet46
    Effort: no CLI flag. Opus 4.6 and Sonnet 4.6 support effort via settings.
    Short Name     Model                    Reasoning
    ─────────────  ─────────────────────    ─────────
    sonnet46       claude-sonnet-4-6        extended thinking
    sonnet45       claude-sonnet-4-5        extended thinking
    sonnet4        claude-sonnet-4-0        no
    opus46         claude-opus-4-6          extended thinking
    opus45         claude-opus-4-5          extended thinking
    haiku          claude-haiku-4-5         no

  Gemini (--agent gemini)                default: 25-pro
    Effort: no CLI flag. 2.5 Pro and 2.5 Flash have configurable thinking.
    Short Name     Model                    Reasoning
    ─────────────  ─────────────────────    ─────────
    25-pro         gemini-2.5-pro           thinking
    25-flash       gemini-2.5-flash         thinking
    2-flash        gemini-2.0-flash         no
    3-flash        gemini-3-flash-preview   no
    31-pro         gemini-3.1-pro-preview   no

  Codex (--agent codex)                  default: gpt54
    Effort: supported via -c model_reasoning_effort (low/medium/high).
    Short Name     Model                    Reasoning
    ─────────────  ─────────────────────    ─────────
    gpt54          gpt-5.4                  effort (l/m/h/xh)
    gpt54m         gpt-5.4-mini             effort (l/m/h/xh)
    gpt53c         gpt-5.3-codex            effort (l/m/h/xh)
    gpt53cs        gpt-5.3-codex-spark      effort (l/m/h/xh)
    gpt52          gpt-5.2                  effort (l/m/h/xh)
    gpt41          gpt-4.1                  no
    gpt41m         gpt-4.1-mini             no
    gpt41n         gpt-4.1-nano             no
    o4m            o4-mini                  native reasoning
    o3m            o3-mini                  native reasoning
HELP
            exit 0 ;;
        *)
            echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

# --- Helpers ------------------------------------------------------------------

log()  { echo "[abr] $(date +%H:%M:%S) $*"; }
logr() { echo "[abr] $(date +%H:%M:%S) $*" >&2; }

print_logo() {
        cat <<'LOGO'

        _    ____  ____
     / \  | __ )|  _ \
    / _ \ |  _ \| |_) |
 / ___ \| |_) |  _ <
/_/   \_\____/|_| \_\

            <  abr  >
 your parallel agent manager

LOGO
}

# --- Gum and prompt helpers ---------------------------------------------------

init_ui_support() {
    if command -v gum >/dev/null 2>&1; then
        GUM_AVAILABLE=true
    else
        GUM_AVAILABLE=false
    fi
}

prompt_choose() {
    local prompt="$1"
    shift
    local num_items=$#
    if [[ "$GUM_AVAILABLE" == "true" ]]; then
        # Expand the tmux pane to fit all options, then restore afterwards.
        # needed = items + header(1) + filter(1) + gum padding/border(2) + spare(1) = items + 5
        local needed=$(( num_items + 5 ))
        local original_height="" resized=false
        if [[ -n "${TMUX_PANE:-}" ]]; then
            original_height=$(tmux display-message -t "$TMUX_PANE" -p '#{pane_height}' 2>/dev/null || echo "")
            if [[ -n "$original_height" ]] && (( needed > original_height )); then
                tmux resize-pane -t "$TMUX_PANE" -y "$needed" 2>/dev/null && resized=true || true
                # Brief pause so the pty resize propagates before gum queries terminal size
                [[ "$resized" == "true" ]] && sleep 0.05 || true
            fi
        fi
        # Disable errexit around gum so the restore always runs even if gum exits non-zero
        set +e
        gum choose --header "$prompt" --height "$num_items" "$@"
        local rc=$?
        set -e
        if [[ "$resized" == "true" ]] && [[ -n "$original_height" ]]; then
            tmux resize-pane -t "$TMUX_PANE" -y "$original_height" 2>/dev/null || true
        fi
        return $rc
    fi
    echo "$prompt" >&2
    local i=1
    for item in "$@"; do
        echo "  $i) $item" >&2
        i=$((i + 1))
    done
    printf "Enter choice [1-%d]: " "$#" >&2
    local pick
    read -r pick
    if [[ ! "$pick" =~ ^[0-9]+$ ]] || [[ "$pick" -lt 1 ]] || [[ "$pick" -gt "$#" ]]; then
        return 1
    fi
    # Walk positional args to avoid eval
    local _i=1
    for _item; do
        [[ $_i -eq $pick ]] && echo "$_item" && break
        _i=$(( _i + 1 ))
    done
}

prompt_input() {
    local prompt="$1"
    local placeholder="${2:-}"
    if [[ "$GUM_AVAILABLE" == "true" ]]; then
        gum input --prompt "$prompt " --placeholder "$placeholder"
        return $?
    fi
    printf "%s " "$prompt" >&2
    read -r value
    echo "$value"
}

prompt_confirm() {
    local prompt="$1"
    if [[ "$GUM_AVAILABLE" == "true" ]]; then
        gum confirm "$prompt"
        return $?
    fi
    printf "%s [y/N]: " "$prompt" >&2
    local yn
    read -r yn
    [[ "$yn" =~ ^[Yy]$ ]]
}

persist_default_setting() {
    local key="$1"
    local value="$2"
    local conf_file="${REPO_ROOT}/.abr.conf"
    touch "$conf_file"
    grep -v "^${key}[[:space:]]*=" "$conf_file" > "${conf_file}.tmp" || true
    printf '%s = %s\n' "$key" "$value" >> "${conf_file}.tmp"
    mv "${conf_file}.tmp" "$conf_file"
}

select_count_quick_custom() {
    local title="$1"
    local choice
    choice=$(prompt_choose "$title" "1" "2" "3" "4" "custom") || return 1
    if [[ "$choice" == "custom" ]]; then
        local custom
        custom=$(prompt_input "Enter integer (>4):" "5") || return 1
        if [[ ! "$custom" =~ ^[0-9]+$ ]] || [[ "$custom" -le 4 ]]; then
            printf '\e[31mCustom value must be an integer greater than 4 (use the quick options for 1–4).\e[0m\n' >&2
            return 1
        fi
        echo "$custom"
        return 0
    fi
    echo "$choice"
}

# Map a human status name to the correct bd CLI args.
# "ready" uses the blocker-aware subcommand; everything else uses bd list --status.
_bd_args_for_status() {
    local status="$1"
    case "$status" in
        ready)       echo "ready --json" ;;
        in-progress) echo "list --status in_progress --json" ;;
        closed)      echo "list --status closed --json --all" ;;
        *)           echo "list --status $status --json" ;;
    esac
}

_parse_bead_ids_from_json() {
    python3 -c '
import json,sys
try:
    data = json.load(sys.stdin)
except Exception:
    sys.exit(0)
if isinstance(data, dict):
    data = data.get("issues", [])
for issue in data:
    bid = issue.get("id")
    if bid:
        print(bid)
'
}

# Like _parse_bead_ids_from_json but outputs "id<TAB>title" per bead.
_parse_bead_titles_from_json() {
    python3 -c '
import json, sys
try:
    data = json.load(sys.stdin)
except Exception:
    sys.exit(0)
if isinstance(data, dict):
    data = data.get("issues", [])
for issue in data:
    bid = issue.get("id", "")
    title = issue.get("title", "")
    if bid:
        print(bid + "\t" + title)
'
}

get_bead_ids_for_status() {
    local status="$1"
    local -a bd_args
    read -r -a bd_args <<< "$(_bd_args_for_status "$status")"
    bd_locked "${bd_args[@]}" 2>/dev/null | _parse_bead_ids_from_json
}

# Read-only status fetch used by non-mutating UI commands.
get_bead_ids_for_status_unlocked() {
    local status="$1"
    local -a bd_args
    read -r -a bd_args <<< "$(_bd_args_for_status "$status")"
    bd "${bd_args[@]}" 2>/dev/null | _parse_bead_ids_from_json
}

# Returns bead IDs for a status, but caps wait time to keep C&C responsive.
# Emits IDs on stdout and returns 0 on success, 124 on timeout.
get_bead_ids_for_status_timed() {
    local status="$1"
    local timeout_s="${2:-5}"
    local tmp
    tmp=$(mktemp)

    (get_bead_ids_for_status_unlocked "$status" > "$tmp") &
    local pid=$!
    local ticks=$((timeout_s * 10))

    while [[ $ticks -gt 0 ]]; do
        if ! kill -0 "$pid" 2>/dev/null; then
            wait "$pid" 2>/dev/null || true
            cat "$tmp"
            rm -f "$tmp"
            return 0
        fi
        sleep 0.1
        ticks=$((ticks - 1))
    done

    kill "$pid" 2>/dev/null || true
    wait "$pid" 2>/dev/null || true
    rm -f "$tmp"
    return 124
}

# Like get_bead_ids_for_status_timed but outputs "id<TAB>title" pairs.
# Returns 0 on success, 124 on timeout.
get_beads_with_titles_timed() {
    local status="$1"
    local timeout_s="${2:-5}"
    local -a bd_args
    read -r -a bd_args <<< "$(_bd_args_for_status "$status")"
    local tmp
    tmp=$(mktemp)
    (bd "${bd_args[@]}" 2>/dev/null | _parse_bead_titles_from_json > "$tmp") &
    local pid=$!
    local ticks=$((timeout_s * 10))
    while [[ $ticks -gt 0 ]]; do
        if ! kill -0 "$pid" 2>/dev/null; then
            wait "$pid" 2>/dev/null || true
            cat "$tmp"
            rm -f "$tmp"
            return 0
        fi
        sleep 0.1
        ticks=$((ticks - 1))
    done
    kill "$pid" 2>/dev/null || true
    wait "$pid" 2>/dev/null || true
    rm -f "$tmp"
    return 124
}

cc_render_status_bar() {
    local ipc_dir="$1"
    local num_workers="$2"
    local running=0 idle=0
    local session
    session=$(tmux display-message -p '#{session_name}' 2>/dev/null || echo "")

    for (( i=1; i<=num_workers; i++ )); do
        local pane_file="${ipc_dir}/pane-A${i}"
        [[ -f "$pane_file" ]] || continue
        local pane_id
        pane_id=$(<"$pane_file")
        [[ -n "$pane_id" ]] || continue
        if [[ -n "$session" ]] && tmux list-panes -t "$session" -F '#{pane_id} #{pane_current_command}' 2>/dev/null | grep -q "^${pane_id} "; then
            local cmd
            cmd=$(tmux list-panes -t "$session" -F '#{pane_id} #{pane_current_command}' 2>/dev/null | awk -v p="$pane_id" '$1==p{print $2}')
            if [[ "$cmd" == "abr" ]]; then
                running=$((running + 1))
            else
                idle=$((idle + 1))
            fi
        fi
    done

    local ready_count open_count inprog_count
    ready_count=$(get_bead_ids_for_status_unlocked "ready" | wc -l | tr -d ' ')
    open_count=$(get_bead_ids_for_status_unlocked "open" | wc -l | tr -d ' ')
    inprog_count=$(get_bead_ids_for_status_unlocked "in-progress" | wc -l | tr -d ' ')
    local total_not_closed=$((ready_count + open_count + inprog_count))

    local model_display="${MODEL:-auto}"
    if [[ "$GUM_AVAILABLE" == "true" ]]; then
        local a_styled m_styled run_styled idle_styled
        a_styled=$(gum style --bold --foreground 6 "$AGENT_TOOL" 2>/dev/null || echo "$AGENT_TOOL")
        m_styled=$(gum style --bold --foreground 6 "$model_display" 2>/dev/null || echo "$model_display")
        run_styled=$(gum style --bold --foreground 2 "$running" 2>/dev/null || echo "$running")
        idle_styled=$(gum style --bold --foreground 3 "$idle" 2>/dev/null || echo "$idle")
        printf '\e[90m agent:%s  model:%s\e[0m\n' "$a_styled" "$m_styled"
        printf '\e[90m running:%s  idle:%s  not-closed:%d  ready:%d\e[0m\n' "$run_styled" "$idle_styled" "$total_not_closed" "$ready_count"
    else
        printf '\e[90m agent=%-10s model=%-14s\e[0m\n' "$AGENT_TOOL" "$model_display"
        printf '\e[90m \e[32mrunning:%-3d\e[90m \e[33midle:%-3d\e[90m  not-closed:%-4d  ready:%-3d\e[0m\n' "$running" "$idle" "$total_not_closed" "$ready_count"
    fi
}

# --- Serialize bd access (embedded Dolt supports only one writer) -------------
#
# Uses mkdir-based mutex (atomic on POSIX, works on macOS without flock).
# All script-level bd calls that may write go through bd_locked() so parallel
# agents queue instead of crashing with "another process holds the exclusive lock".

BD_LOCKDIR="${REPO_ROOT}/.beads/.bd.lock"
BD_LOCK_TIMEOUT=90  # seconds

bd_locked() {
    local waited=0
    while ! mkdir "$BD_LOCKDIR" 2>/dev/null; do
        # Detect stale lock (owning process is gone)
        if [[ -f "$BD_LOCKDIR/pid" ]]; then
            local lock_pid
            lock_pid=$(cat "$BD_LOCKDIR/pid" 2>/dev/null || echo "")
            if [[ -n "$lock_pid" ]] && ! kill -0 "$lock_pid" 2>/dev/null; then
                log "Breaking stale bd lock (pid $lock_pid is gone)"
                rm -rf "$BD_LOCKDIR"
                continue
            fi
        fi
        if [[ $waited -ge $BD_LOCK_TIMEOUT ]]; then
            log "bd lock timed out after ${BD_LOCK_TIMEOUT}s — breaking lock"
            rm -rf "$BD_LOCKDIR"
            continue
        fi
        sleep 1
        waited=$((waited + 1))
    done

    # Record holder for stale detection
    echo $$ > "$BD_LOCKDIR/pid" 2>/dev/null || true

    # Capture exit code without letting set -e kill the script and orphan the lock dir.
    local rc=0
    bd "$@" || rc=$?

    rm -rf "$BD_LOCKDIR"
    return $rc
}

# --- Graceful stop support ----------------------------------------------------

STOP_REQUESTED=false
STOP_FILE="${REPO_ROOT}/.agent-stop"

request_stop() {
    STOP_REQUESTED=true
    log "Stop requested — will finish current bead and exit."
}

# SIGUSR1: explicit stop signal (kill -USR1 <pid>)
trap 'request_stop' USR1
# SIGINT (Ctrl+C): first press requests graceful stop; second press exits immediately
trap 'if [[ "$STOP_REQUESTED" == "true" ]]; then log "Force quit."; exit 130; else request_stop; fi' INT

should_stop() {
    # Check the flag (set by signal handlers)
    [[ "$STOP_REQUESTED" == "true" ]] && return 0
    # Check the stop file (created by another terminal)
    if [[ -f "$STOP_FILE" ]]; then
        rm -f "$STOP_FILE"
        request_stop
        return 0
    fi
    # Check per-agent stop file (written by C&C "stop --target A<n>")
    if [[ -n "${ABR_AGENT_IDX:-}" ]]; then
        local per_agent_stop="${WORKTREE_BASE}/.abr-ipc/stop-A${ABR_AGENT_IDX}"
        if [[ -f "$per_agent_stop" ]]; then
            rm -f "$per_agent_stop"
            request_stop
            return 0
        fi
    fi
    return 1
}

pick_next_bead() {
    cd "$REPO_ROOT"
    bd_locked ready --json 2>/dev/null \
        | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    issues = data if isinstance(data, list) else data.get('issues', [])
    # Sort by priority ascending (lower = higher priority), then prefer deeper
    # sub-beads (longer ID) as a tiebreaker within the same priority level.
    issues.sort(key=lambda x: (x.get('priority', 2), -len(x.get('id', ''))))
    if issues:
        print(issues[0]['id'])
except Exception:
    sys.exit(1)
" 2>/dev/null || echo ""
}

pick_n_beads() {
    local n="$1"
    cd "$REPO_ROOT"
    bd_locked ready --json 2>/dev/null \
        | python3 -c "
import sys, json
n = int(sys.argv[1])
try:
    data = json.load(sys.stdin)
    issues = data if isinstance(data, list) else data.get('issues', [])
    issues.sort(key=lambda x: (x.get('priority', 2), -len(x.get('id', ''))))
    for issue in issues[:n]:
        print(issue['id'])
except Exception:
    sys.exit(1)
" "$n" 2>/dev/null || echo ""
}

sanitize_branch() {
    echo "agent/$1" | tr '.' '-'
}

claim_bead() {
    local bead_id="$1"
    local max_attempts="${2:-3}"
    local attempt

    cd "$REPO_ROOT"
    for attempt in $(seq 1 "$max_attempts"); do
        if bd_locked update "$bead_id" --claim 2>/dev/null; then
            # Push claim to remote so parallel agents see it
            bd_locked dolt push 2>/dev/null || true
            # Signal push completion so loop panes know a pull is now useful
            ipc_signal_pushed
            return 0
        fi
        [[ $attempt -lt $max_attempts ]] && sleep $(( (RANDOM % 3) + 1 ))
    done
    return 1
}

# --- IPC: filesystem-based inter-agent signalling ----------------------------
# Zero-dependency pub/sub using the local filesystem. All state lives under
# ${WORKTREE_BASE}/.abr-ipc/ which is on the same mount as the worktrees so
# file creation is atomic and visible to every tmux pane instantly.
#
# Events:
#   claimed/<bead_id>   Written by the claiming pane right after bd --claim
#                       succeeds, BEFORE dolt push finishes. Other panes see
#                       this and skip the bead even while the push is in-flight.
#   last_push           Touched after every dolt push. Other panes compare
#                       their own last_pull_<PID> stamp against this to decide
#                       whether a pull is actually useful.
#   last_pull_<PID>     Per-loop-process stamp; updated after each pull.

ipc_signal_claimed() {
    local dir="${WORKTREE_BASE}/.abr-ipc/claimed"
    mkdir -p "$dir"
    echo "$$" > "${dir}/$1"
}

ipc_is_claimed() { [[ -f "${WORKTREE_BASE}/.abr-ipc/claimed/$1" ]]; }

ipc_clear_claim() { rm -f "${WORKTREE_BASE}/.abr-ipc/claimed/$1"; }

ipc_signal_pushed() {
    mkdir -p "${WORKTREE_BASE}/.abr-ipc"
    touch "${WORKTREE_BASE}/.abr-ipc/last_push"
}

# Returns 0 (pull needed) when:
#   - this process has never pulled (first iteration), OR
#   - another agent pushed since our last pull.
# In solo mode (no last_push file) always pulls so we see remote changes.
ipc_needs_pull() {
    local our_stamp="${WORKTREE_BASE}/.abr-ipc/last_pull_$$"
    local push_stamp="${WORKTREE_BASE}/.abr-ipc/last_push"
    [[ ! -f "$our_stamp" ]] && return 0                                         # first iteration
    [[ ! -f "$push_stamp" ]] && return 0                                        # solo mode, no signals
    [[ "$push_stamp" -nt "$our_stamp" ]] && return 0                            # new push arrived
    return 1
}

ipc_record_pull() {
    mkdir -p "${WORKTREE_BASE}/.abr-ipc"
    touch "${WORKTREE_BASE}/.abr-ipc/last_pull_$$"
}

# Remove per-process state when this loop process exits.
ipc_cleanup_self() { rm -f "${WORKTREE_BASE}/.abr-ipc/last_pull_$$"; }

# Append a structured event to the shared orchestrator event log.
# Format: HH:MM:SS|AGENT_IDX|LEVEL|message
# No-op when no orchestrator session is active (log file not present).
# ABR_AGENT_IDX is set via env var when each worker pane is launched.
ipc_event() {
    local level="$1"
    local message="$2"
    local log="${WORKTREE_BASE}/.abr-ipc/events.log"
    [[ -f "$log" ]] || return 0
    printf '%s|%s|%s|%s\n' "$(date +%H:%M:%S)" "${ABR_AGENT_IDX:-?}" "$level" "$message" >> "$log"
}

# --- Orchestrator dashboard ---------------------------------------------------
# Launched in the center pane via --internal-orchestrator <num_workers>.
# Reads the shared event log and renders a live, colour-coded summary until
# all worker panes have sent an EXIT event, then prints a final tallly.

run_orchestrator() {
    local num_workers="${1:-1}"
    local log="${WORKTREE_BASE}/.abr-ipc/events.log"
    local _nw_file="${WORKTREE_BASE}/.abr-ipc/num_workers"
    local script_path
    script_path="$(command -v abr 2>/dev/null || echo "$0")"
    local gum_flag=""
    command -v gum >/dev/null 2>&1 && gum_flag=" · gum ✓"

    # Split a 4-line C&C prompt pane below this orchestrator pane.
    # TMUX_PANE is set automatically by tmux in each pane's shell environment.
    if [[ -n "${TMUX:-}" && -n "${TMUX_PANE:-}" ]]; then
        local cc_pane
        cc_pane=$(tmux split-window -v -l 4 -P -F '#{pane_id}' -t "${TMUX_PANE}" \
            "cd '${REPO_ROOT}' && '${script_path}' --internal-cc ${num_workers}; printf '\033[90m[C&C closed]\033[0m\n'; read -r _")
        tmux select-pane -t "$cc_pane"
    fi

    printf '\e[1;36m╔══════════════════════════════════════════╗\e[0m\n'
    printf '\e[1;36m║  ABR Orchestrator  ·  %d worker(s)%-9s║\e[0m\n' "$num_workers" "${gum_flag}"
    printf '\e[1;36m╚══════════════════════════════════════════╝\e[0m\n'
    printf '\e[90mWaiting for agents to start… (type \e[0m/help\e[90m in C&C below)\e[0m\n'
    printf '\e[90mLogs: /tmp/abr-%s/  (deleted on /exit — view with: less -R <file>)\e[0m\n\n' "${TMUX_SESSION}"

    # Wait up to 30s for the event log to appear (workers may not have started yet)
    local waited=0
    while [[ ! -f "$log" ]] && [[ $waited -lt 60 ]]; do
        sleep 0.5; waited=$((waited + 1))
    done
    if [[ ! -f "$log" ]]; then
        printf '\e[31mEvent log never appeared after 30s. Exiting orchestrator.\e[0m\n'
        return 1
    fi

    local exit_count=0 claim_count=0 done_count=0 error_count=0 pr_count=0 merge_count=0 session_num=0

    # Use a FIFO so we can break cleanly from the read loop (subshell-free)
    local orch_fifo
    orch_fifo=$(mktemp -u /tmp/abr-orch-XXXXXX)
    mkfifo "$orch_fifo"
    tail -n +1 -f "$log" 2>/dev/null > "$orch_fifo" &
    local tail_pid=$!

    while IFS='|' read -r ts idx level msg; do
        level="${level// /}"          # strip any stray whitespace
        msg="${msg%$'\r'}"            # strip carriage returns
        local label
        label="$(printf '\e[90m[%s A%s]\e[0m' "$ts" "$idx")"
        case "$level" in
            CLAIM)
                (( claim_count++ )) || true
                printf '%s \e[33mCLAIM \e[0m %s\n' "$label" "$msg" ;;
            START)
                printf '%s \e[34mSTART \e[0m %s\n' "$label" "$msg" ;;
            PR)
                (( pr_count++ )) || true
                printf '%s \e[32mPR    \e[0m %s\n' "$label" "$msg" ;;
            DONE)
                (( done_count++ )) || true
                printf '%s \e[32mDONE  \e[0m %s\n' "$label" "$msg" ;;
            MERGE)
                (( merge_count++ )) || true
                (( done_count++ )) || true
                printf '%s \e[32mMERGE \e[0m %s\n' "$label" "$msg" ;;
            ERROR)
                (( error_count++ )) || true
                printf '%s \e[31mERROR \e[0m %s\n' "$label" "$msg" ;;
            EXIT)
                printf '%s \e[90mEXIT  \e[0m %s\n' "$label" "$msg"
                (( exit_count++ )) || true
                # Re-read worker count (may have been updated by /start, /go, /review)
                local _cur_nw
                _cur_nw=$(cat "$_nw_file" 2>/dev/null || echo "$num_workers")
                if [[ $exit_count -ge $_cur_nw ]]; then
                    (( session_num++ )) || true
                    printf '\n\e[1;36m════════ Session %d Summary ════════\e[0m\n' "$session_num"
                    [[ $claim_count -gt 0 ]] && printf '  Beads claimed:   %d\n' "$claim_count"
                    printf '  Items done:      %d\n' "$done_count"
                    [[ $pr_count -gt 0 ]]    && printf '  PRs created:     %d\n' "$pr_count"
                    [[ $merge_count -gt 0 ]] && printf '  PRs merged:      %d\n' "$merge_count"
                    [[ $error_count -gt 0 ]] && printf '\e[31m  Errors:          %d\e[0m\n' "$error_count" \
                                              || printf '  Errors:          0\n'
                    printf '\e[1;36m════════════════════════════════════\e[0m\n'
                    printf '\e[90m── Session %d done · Watching for next session (type \e[0m/exit\e[90m in C&C to quit) ──\e[0m\n\n' "$session_num"
                    exit_count=0; claim_count=0; done_count=0; error_count=0; pr_count=0; merge_count=0
                fi
                ;;
            INFO)
                printf '%s \e[90mINFO  \e[0m %s\n' "$label" "$msg" ;;
            *)
                printf '%s \e[90m%-5s \e[0m %s\n' "$label" "$level" "$msg" ;;
        esac
    done < "$orch_fifo"

    kill "$tail_pid" 2>/dev/null || true
    wait "$tail_pid" 2>/dev/null || true   # reap to suppress shell "Terminated" job notice
    rm -f "$orch_fifo"
}

# --- Command & Control prompt -------------------------------------------------
# Launched in the 4-line bottom slice of the orchestrator pane via
# --internal-cc <num_workers>.  Presents an interactive abr> prompt that
# can target, stop, kill, or hot-swap individual worker panes.

run_cc() {
    local initial_num_workers="${1:-1}"
    local ipc_dir="${WORKTREE_BASE}/.abr-ipc"
    local log="${ipc_dir}/events.log"
    local _nw_file="${ipc_dir}/num_workers"

    # Persist current worker count so /start can expand it dynamically
    echo "$initial_num_workers" > "$_nw_file"

    # Wait briefly for the event log to exist (orchestrator creates it)
    local w=0
    while [[ ! -f "$log" ]] && [[ $w -lt 20 ]]; do sleep 0.5; w=$((w+1)); done

    printf '\e[90m─── C&C ready · \e[0m/\e[90m = command picker · \e[0m/help\e[90m for list ──\e[0m\n'
    while true; do
        # Re-read worker count each iteration (may be expanded by /start)
        local num_workers
        num_workers=$(cat "$_nw_file" 2>/dev/null || echo "$initial_num_workers")
        cc_render_status_bar "$ipc_dir" "$num_workers" || true
        printf '\e[1;36mabr>\e[0m '
        # Read just the first character; "/" opens the interactive command picker
        IFS= read -rn1 first_char || break
        if [[ "$first_char" == "/" ]]; then
            printf '\n'
            # Temporarily expand the C&C pane so gum filter has room to render,
            # then restore it to 4 lines after selection (or on cancel).
            local _pane_id; _pane_id=$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)
            [[ -n "$_pane_id" ]] && tmux resize-pane -t "$_pane_id" -y 14
            cmdline=$(printf '%s\n' \
                "/go      Run one agent on next bead" \
                "/start   Interactive launch wizard" \
                "/agent   Pick and persist default agent" \
                "/model   Pick and persist default model" \
                "/beads   Show kanban-style bead board" \
                "/bead    Pick bead then action menu" \
                "/prune   Prune merged local/remote branches" \
                "/review  Run one review agent on open PRs" \
                "/help    Print command help to dashboard" \
                "/exit    Kill tmux session and return" \
                | gum filter --placeholder "type to filter commands…" \
                              --height 12 --select-if-one)
            local _pick_rc=$?
            [[ -n "$_pane_id" ]] && tmux resize-pane -t "$_pane_id" -y 4
            [[ $_pick_rc -ne 0 ]] && continue
            cmdline="${cmdline%% *}"  # strip description, keep /command
        elif [[ -z "$first_char" ]]; then
            continue
        else
            IFS= read -r rest
            cmdline="${first_char}${rest}"
        fi
        [[ -z "$cmdline" ]] && continue
        local -a words
        read -ra words <<< "$cmdline"
        local cmd="${words[0]}"
        if [[ "$cmd" == /* ]]; then
            cmd="${cmd#/}"
        fi
        local cmd_rc=0
        case "$cmd" in
            go)       cc_cmd_slash_go "$ipc_dir" "$log" "$num_workers" || cmd_rc=$? ;;
            start)    cc_cmd_slash_start "$ipc_dir" "$log" "$_nw_file" || cmd_rc=$? ;;
            agent)    cc_cmd_slash_agent "$log" || cmd_rc=$? ;;
            model)    cc_cmd_slash_model "$log" || cmd_rc=$? ;;
            beads)    cc_cmd_slash_beads "$log" || cmd_rc=$? ;;
            bead)     cc_cmd_slash_bead "$ipc_dir" "$log" "$num_workers" || cmd_rc=$? ;;
            prune)    cc_cmd_slash_prune "$log" || cmd_rc=$? ;;
            review)   cc_cmd_slash_review "$ipc_dir" "$log" "$num_workers" || cmd_rc=$? ;;
            run)      cc_cmd_run    "$ipc_dir" "$log" "$num_workers" "${words[@]:1}" || cmd_rc=$? ;;
            stop)     cc_cmd_stop   "$ipc_dir" "$log"               "${words[@]:1}" || cmd_rc=$? ;;
            kill)     cc_cmd_kill   "$ipc_dir" "$log"               "${words[@]:1}" || cmd_rc=$? ;;
            status)   cc_cmd_status "$ipc_dir" "$log" "$num_workers" || cmd_rc=$? ;;
            help|"?") cc_cmd_help "$log" || cmd_rc=$? ;;
            exit|quit) cc_cmd_shutdown "$log" || cmd_rc=$?; return 0 ;;
            *) printf '\e[33mUnknown command: %s  (type /help)\e[0m\n' "$cmd" ;;
        esac
        if [[ $cmd_rc -ne 0 ]]; then
            printf '\e[31mCommand failed (exit=%d). C&C stays open.\e[0m\n' "$cmd_rc"
        fi
    done
    printf '\e[90m[C&C closed]\e[0m\n'
}

cc_cmd_shutdown() {
    local log="$1"
    local ts; ts=$(date +%H:%M:%S)
    local session
    session=$(tmux display-message -p '#{session_name}' 2>/dev/null || echo "")
    if [[ -z "$session" ]]; then
        printf '\e[31mNo tmux session detected for shutdown.\e[0m\n'
        return 1
    fi
    # Delete the session log directory (created at launch, in /tmp).
    local log_dir="/tmp/abr-${session}"
    if [[ -d "$log_dir" ]]; then
        printf '%s|0|INFO|C&C: deleting session logs %s\n' "$ts" "$log_dir" >> "$log"
        rm -rf "$log_dir"
    fi
    printf '%s|0|INFO|C&C: shutting down tmux session %s\n' "$ts" "$session" >> "$log"
    # This terminates orchestrator + all worker panes, returning to parent terminal.
    tmux kill-session -t "$session"
}

cc_cmd_slash_prune() {
    local log="$1"
    local choice
    choice=$(prompt_choose "Prune which merged branches?" "local" "remote" "both") || {
        printf '\e[31mPrune cancelled.\e[0m\n'
        return 1
    }
    local ts; ts=$(date +%H:%M:%S)
    case "$choice" in
        local)
            printf '%s|0|INFO|C&C: prune local branches requested\n' "$ts" >> "$log"
            prune_local_branches
            ;;
        remote)
            printf '%s|0|INFO|C&C: prune remote branches requested\n' "$ts" >> "$log"
            prune_remote_branches
            ;;
        both)
            printf '%s|0|INFO|C&C: prune local + remote branches requested\n' "$ts" >> "$log"
            prune_local_branches
            prune_remote_branches
            ;;
    esac
}

cc_first_target_alias() {
    local ipc_dir="$1"
    local num_workers="$2"
    for (( i=1; i<=num_workers; i++ )); do
        if [[ -f "${ipc_dir}/pane-A${i}" ]]; then
            echo "A${i}"
            return 0
        fi
    done
    return 1
}

cc_cmd_slash_go() {
    local ipc_dir="$1" log="$2" num_workers="$3"
    local target
    local -a run_args
    target=$(cc_first_target_alias "$ipc_dir" "$num_workers") || {
        printf '\e[31mNo worker panes registered yet.\e[0m\n'
        return 1
    }
    # Tell the orchestrator to expect exactly 1 EXIT event for this single-agent session
    echo "1" > "${ipc_dir}/num_workers"
    run_args=(--target "$target" --agent "$AGENT_TOOL" --single-run)
    [[ -n "$MODEL" ]] && run_args+=(--model "$MODEL")
    cc_cmd_run "$ipc_dir" "$log" "$num_workers" "${run_args[@]}"
}

# /review — start a single review agent on the next open agent PR
cc_cmd_slash_review() {
    local ipc_dir="$1" log="$2" num_workers="$3"
    local target
    local -a run_args
    target=$(cc_first_target_alias "$ipc_dir" "$num_workers") || {
        printf '\e[31mNo worker panes registered yet.\e[0m\n'
        return 1
    }
    # Tell the orchestrator to expect exactly 1 EXIT event for this review session
    echo "1" > "${ipc_dir}/num_workers"
    run_args=(--target "$target" --agent "$AGENT_TOOL" --single-run --review)
    [[ -n "$MODEL" ]] && run_args+=(--model "$MODEL")
    cc_cmd_run "$ipc_dir" "$log" "$num_workers" "${run_args[@]}"
}

cc_cmd_slash_agent() {
    local log="$1"
    local selected
    selected=$(prompt_choose "Select default agent" "copilot" "claude" "gemini" "codex") || {
        printf '\e[31mAgent selection cancelled.\e[0m\n'
        return 1
    }
    AGENT_TOOL="$selected"
    persist_default_setting "agent" "$selected"
    local ts; ts=$(date +%H:%M:%S)
    printf '%s|0|INFO|Default agent set to %s (persisted to .abr.conf)\n' "$ts" "$selected" >> "$log"
    printf '\e[32mDefault agent set to %s\e[0m\n' "$selected"
}

get_model_list_for_agent() {
    case "$1" in
        copilot) echo "sonnet46-h sonnet45-h opus46-h gpt54 gpt54m gpt53c gem25p haiku gpt52 gpt41" ;;
        claude)  echo "sonnet46 sonnet45 opus46 opus45 haiku sonnet4" ;;
        gemini)  echo "25-pro 25-flash 31-pro 3-flash 2-flash" ;;
        codex)   echo "gpt54 gpt54m gpt53c gpt52 gpt41 o4m o3m" ;;
        *)       echo "sonnet46-h gpt54 gem25p" ;;
    esac
}

cc_cmd_slash_model() {
    local log="$1"
    local agent="${2:-$AGENT_TOOL}"
    local -a model_opts
    read -ra model_opts <<< "$(get_model_list_for_agent "$agent")"
    local selected
    selected=$(prompt_choose "Select default model for ${agent}" "${model_opts[@]}") || {
        printf '\e[31mModel selection cancelled.\e[0m\n'
        return 1
    }
    MODEL="$selected"
    persist_default_setting "model" "$selected"
    local ts; ts=$(date +%H:%M:%S)
    printf '%s|0|INFO|Default model set to %s (persisted to .abr.conf)\n' "$ts" "$selected" >> "$log"
    printf '\e[32mDefault model set to %s\e[0m\n' "$selected"
}

# Emit one status-group section as INFO lines to stdout (caller redirects to log).
# Args: <color-escape> <label> <bullet> <ts> [bead-entry…]
# Each bead-entry is "id<TAB>title" (from get_beads_with_titles_timed).
_beads_board_section() {
    local color="$1" label="$2" bullet="$3" ts="$4"
    shift 4
    local -a items=("$@")
    local count="${#items[@]}"
    [[ "${items[0]:-}" == "(timeout)" ]] && count="?"
    printf '%s|0|INFO|%b── %s (%s) ──────────────────────────────────────\e[0m\n' \
        "$ts" "$color" "$label" "$count"
    if [[ ${#items[@]} -eq 0 ]]; then
        printf '%s|0|INFO|\e[90m    (none)\e[0m\n' "$ts"
    else
        local entry id title
        for entry in "${items[@]+"${items[@]}"}"; do
            if [[ "$entry" == "(timeout)" ]]; then
                printf '%s|0|INFO|\e[90m    (timeout fetching beads)\e[0m\n' "$ts"
                break
            fi
            IFS=$'\t' read -r id title <<< "$entry"
            [[ ${#title} -gt 52 ]] && title="${title:0:50}…"
            printf '%s|0|INFO|%b  %s \e[0m%-24s  %s\n' "$ts" "$color" "$bullet" "$id" "$title"
        done
    fi
}

# Fetches all bead statuses and writes a pretty kanban board to the event log.
# Designed to run as a subprocess (abr --internal-beads-board <log>) so that the
# C&C prompt stays responsive while bd queries execute.
_run_beads_board() {
    local log="$1"
    local ts; ts=$(date +%H:%M:%S)
    local -a ready_arr open_arr inprog_arr closed_arr
    local out

    if out=$(get_beads_with_titles_timed "open" 5); then
        while IFS= read -r b; do [[ -n "$b" ]] && open_arr+=("$b"); done <<< "$out"
    else
        open_arr=("(timeout)")
    fi

    if out=$(get_beads_with_titles_timed "in-progress" 5); then
        while IFS= read -r b; do [[ -n "$b" ]] && inprog_arr+=("$b"); done <<< "$out"
    else
        inprog_arr=("(timeout)")
    fi

    if out=$(get_beads_with_titles_timed "closed" 5); then
        while IFS= read -r b; do [[ -n "$b" ]] && closed_arr+=("$b"); done <<< "$out"
    else
        closed_arr=("(timeout)")
    fi

    if out=$(get_beads_with_titles_timed "ready" 5); then
        while IFS= read -r b; do [[ -n "$b" ]] && ready_arr+=("$b"); done <<< "$out"
    else
        ready_arr=("(timeout)")
    fi

    {
        printf '%s|0|INFO|\e[1;37m════════════════ Beads Board ════════════════════════\e[0m\n' "$ts"
        _beads_board_section '\e[33m' "OPEN BEADS"        '●' "$ts" "${open_arr[@]+"${open_arr[@]}"}" 
        _beads_board_section '\e[36m' "IN PROGRESS BEADS" '◎' "$ts" "${inprog_arr[@]+"${inprog_arr[@]}"}" 
        _beads_board_section '\e[32m' "CLOSED BEADS"      '✓' "$ts" "${closed_arr[@]+"${closed_arr[@]}"}" 
        _beads_board_section '\e[34m' "READY BEADS"       '▶' "$ts" "${ready_arr[@]+"${ready_arr[@]}"}" 
        printf '%s|0|INFO|\e[1;37m═════════════════════════════════════════════════════\e[0m\n' "$ts"
    } >> "$log"
}

cc_cmd_slash_beads() {
    local log="$1"
    local script_path
    script_path="$(command -v abr 2>/dev/null || echo "$0")"
    local ts; ts=$(date +%H:%M:%S)

    # Always fire-and-forget so the C&C cursor remains interactive.
    printf '%s|0|INFO|C&C: fetching bead board in background\n' "$ts" >> "$log"
    printf '\e[90m(fetching bead board in background…)\e[0m\n'
    "$script_path" --internal-beads-board "$log" >/dev/null 2>&1 &
    disown $! 2>/dev/null || true
}

cc_select_active_bead() {
    local beads
    beads=$( { get_bead_ids_for_status "ready"; get_bead_ids_for_status "open"; get_bead_ids_for_status "in-progress"; } | awk 'NF')
    [[ -n "$beads" ]] || return 1
    local -a opts=()
    while IFS= read -r bead; do
        [[ -n "$bead" ]] && opts+=("$bead")
    done <<< "$beads"
    prompt_choose "Select bead" "${opts[@]}"
}

cc_cmd_slash_bead() {
    local ipc_dir="$1" log="$2" num_workers="$3"
    local bead
    bead=$(cc_select_active_bead) || {
        printf '\e[31mNo active beads available to select.\e[0m\n'
        return 1
    }
    local action
    action=$(prompt_choose "Action for ${bead}" "send to an agent" "show info" "close") || return 1
    case "$action" in
        "send to an agent")
            local target
            local -a run_args
            target=$(cc_first_target_alias "$ipc_dir" "$num_workers") || return 1
            run_args=(--target "$target" --agent "$AGENT_TOOL" --bead "$bead" --single-run)
            [[ -n "$MODEL" ]] && run_args+=(--model "$MODEL")
            cc_cmd_run "$ipc_dir" "$log" "$num_workers" "${run_args[@]}"
            ;;
        "show info")
            bd_locked show "$bead" || true
            ;;
        "close")
            if prompt_confirm "Close bead ${bead}?"; then
                if bd_locked close "$bead"; then
                    printf '\e[32mClosed bead %s\e[0m\n' "$bead"
                    printf '%s|0|INFO|Closed bead %s via /bead\n' "$(date +%H:%M:%S)" "$bead" >> "$log"
                else
                    printf '\e[31mFailed to close bead %s\e[0m\n' "$bead"
                fi
            fi
            ;;
    esac
}

_cc_spawn_idle_pane() {
    local ipc_dir="$1"
    local idx="$2"
    local script_path
    script_path="$(command -v abr 2>/dev/null || echo "$0")"
    local session
    session=$(tmux display-message -p '#{session_name}' 2>/dev/null || echo "")
    [[ -z "$session" ]] && return 1
    local idle_cmd="export ABR_AGENT_IDX=${idx}; printf '%s' \"\$TMUX_PANE\" > '${ipc_dir}/pane-A${idx}'; printf '\\033[90m[A${idx} idle] Use /go or /start from C&C to launch\\033[0m\\n'; read -r _"
    tmux split-window -v -t "${session}" "$idle_cmd" 2>/dev/null || return 1
    tmux select-layout -t "${session}" tiled 2>/dev/null || true
    sleep 0.4   # brief wait for pane to register its TMUX_PANE
}

cc_cmd_slash_start() {
    local ipc_dir="$1" log="$2" _nw_file="$3"
    local num_workers
    num_workers=$(cat "$_nw_file" 2>/dev/null || echo "4")
    local work_target agent_count loop_count chosen_agent chosen_model

    work_target=$(prompt_choose "Step 1: what do you want to work on?" "next ready bead(s)" "specific bead") || return 1
    agent_count=$(select_count_quick_custom "Step 2: how many agents?") || {
        printf '\e[31mInvalid agent count.\e[0m\n'
        return 1
    }
    loop_count=$(select_count_quick_custom "Step 3: how many loops per agent?") || {
        printf '\e[31mInvalid loop count.\e[0m\n'
        return 1
    }
    chosen_agent=$(prompt_choose "Step 4: choose agent (current: ${AGENT_TOOL})" "copilot" "claude" "gemini" "codex") || return 1

    # Step 5: show only models relevant to chosen agent
    local -a model_opts
    read -ra model_opts <<< "$(get_model_list_for_agent "$chosen_agent")"
    chosen_model=$(prompt_choose "Step 5: choose model for ${chosen_agent} (current: ${MODEL:-auto})" "${model_opts[@]}") || return 1

    if ! prompt_confirm "Step 6: GO — ${agent_count} agent(s)  loops=${loop_count}  ${chosen_agent}/${chosen_model}?"; then
        printf '\e[90mLaunch cancelled.\e[0m\n'
        return 0
    fi

    # Expand worker panes if more are needed than currently available
    if [[ "$agent_count" -gt "$num_workers" ]]; then
        local needed=$(( agent_count - num_workers ))
        printf '\e[33mNeed %d more worker pane(s). Spawning…\e[0m\n' "$needed"
        local n
        for (( n=num_workers+1; n<=agent_count; n++ )); do
            if _cc_spawn_idle_pane "$ipc_dir" "$n"; then
                printf '\e[32mSpawned pane A%d\e[0m\n' "$n"
            else
                printf '\e[31mFailed to spawn pane A%d — launching with %d agent(s)\e[0m\n' "$n" "$((n-1))"
                agent_count=$((n - 1))
                break
            fi
        done
        echo "$agent_count" > "$_nw_file"
        num_workers="$agent_count"
    fi

    local specific_bead=""
    if [[ "$work_target" == "specific bead" ]]; then
        specific_bead=$(cc_select_active_bead) || {
            printf '\e[31mNo bead selected.\e[0m\n'
            return 1
        }
        if [[ "$agent_count" -gt 1 ]]; then
            printf '\e[33mSpecific bead with multiple agents: only pane A1 will receive the specific bead; others get next ready.\e[0m\n'
        fi
    fi

    # Tell the orchestrator how many EXIT events to expect for this session
    echo "$agent_count" > "$_nw_file"

    local i
    for (( i=1; i<=agent_count; i++ )); do
        local target="A${i}"
        local -a run_args=(--target "$target" --agent "$chosen_agent" --model "$chosen_model")
        if [[ -n "$specific_bead" ]] && [[ $i -eq 1 ]]; then
            run_args+=(--bead "$specific_bead" --single-run)
        elif [[ "$loop_count" -gt 1 ]]; then
            run_args+=("--loop-${loop_count}")
        else
            run_args+=(--single-run)
        fi
        cc_cmd_run "$ipc_dir" "$log" "$num_workers" "${run_args[@]}"
    done
}

# Resolve a logical alias (A1, A2…) to a tmux pane ID (%N).
# Prints the pane ID to stdout; prints an error message and returns 1 on failure.
cc_resolve_target() {
    local target="$1"
    local ipc_dir="$2"
    if [[ ! "$target" =~ ^A[0-9]+$ ]]; then
        printf '\e[31mInvalid target "%s" — use A1, A2, etc.\e[0m\n' "$target"
        return 1
    fi
    local pane_file="${ipc_dir}/pane-${target}"
    if [[ ! -f "$pane_file" ]]; then
        printf '\e[31mTarget %s not registered (worker may not have started yet)\e[0m\n' "$target"
        return 1
    fi
    local pane_id
    pane_id=$(<"$pane_file")
    if [[ -z "$pane_id" ]]; then
        printf '\e[31mTarget %s has an empty pane ID\e[0m\n' "$target"
        return 1
    fi
    echo "$pane_id"
}

# Extract the value following --flag from a positional argument list.
# Usage: cc_flag "--flag" "$@"   (returns non-zero when flag is absent)
cc_flag() {
    local flag="$1"; shift
    local found=false
    for arg; do
        [[ "$found" == "true" ]] && { echo "$arg"; return 0; }
        [[ "$arg" == "$flag" ]] && found=true
    done
    return 1
}

# run --target A1 [--agent AGENT] [--model MODEL] [extra abr flags…]
# Hot-swaps the agent in the target pane via tmux respawn-pane -k.
# Defaults to --loop; pass --loop-N or --bead to override.
cc_cmd_run() {
    local ipc_dir="$1" log="$2" num_workers="$3"
    shift 3
    local target="" model="" agent="" bead=""
    local single_run=false
    target=$(cc_flag "--target" "$@") || true
    model=$(cc_flag  "--model"  "$@") || true
    agent=$(cc_flag  "--agent"  "$@") || true
    bead=$(cc_flag   "--bead"   "$@") || true
    for arg; do
        [[ "$arg" == "--single-run" ]] && single_run=true
    done

    # Collect extra flags (anything that is not recognized local routing args)
    local extra_flags=() skip_next=false
    for arg; do
        if [[ "$skip_next" == "true" ]]; then skip_next=false; continue; fi
        case "$arg" in
            --target|--model|--agent|--bead) skip_next=true ;;
            --single-run) ;;
            *) extra_flags+=("$arg") ;;
        esac
    done

    if [[ -z "$target" ]]; then
        printf '\e[31mrun: --target required  (e.g. run --target A1 --model gpt5m-h)\e[0m\n'
        return 1
    fi
    local pane_id
    pane_id=$(cc_resolve_target "$target" "$ipc_dir") || return 1
    local idx="${target#A}"
    local script_path
    script_path="$(command -v abr 2>/dev/null || echo "$0")"

    local flags=""
    if [[ "$single_run" != "true" ]]; then
        flags="--loop"
    else
        flags="--no-tui"
    fi
    [[ -n "$agent" ]] && flags+=" --agent $agent"
    [[ -n "$model" ]] && flags+=" --model $model"
    [[ -n "$bead" ]] && flags+=" --bead $bead"
    [[ ${#extra_flags[@]} -gt 0 ]] && flags+=" ${extra_flags[*]}"

    # Clear any stale per-agent stop file so the new worker starts cleanly
    rm -f "${ipc_dir}/stop-A${idx}"

    # Derive log dir from current session name (consistent with launch-time ABR_LOG_DIR)
    local run_log_dir="/tmp/abr-$(tmux display-message -p '#{session_name}' 2>/dev/null || echo abr)"

    # $TMUX_PANE is evaluated by the shell in the new pane (deferred via \$)
    local new_cmd="export ABR_AGENT_IDX=${idx}; printf '%s' \"\$TMUX_PANE\" > '${ipc_dir}/pane-${target}'; tmux pipe-pane -t \"\$TMUX_PANE\" -o \"cat >> '${run_log_dir}/agent-${target}.log'\"; cd '${REPO_ROOT}' && '${script_path}' ${flags}; printf '\n=== Pane finished. Press Enter to close ===\n'; read -r _"
    if tmux respawn-pane -k -t "$pane_id" "$new_cmd" 2>/dev/null; then
        printf '%s|0|INFO|C&C: respawned %s (%s)  →  abr %s\n' \
            "$(date +%H:%M:%S)" "$target" "$pane_id" "$flags" >> "$log"
        printf '\e[32mRespawned %s (%s) with: abr %s\e[0m\n' "$target" "$pane_id" "$flags"
    else
        printf '\e[31mFailed to respawn %s (%s) — pane may no longer exist\e[0m\n' "$target" "$pane_id"
    fi
}

# stop --target A2
# Writes a per-agent stop file and sends C-c so the worker exits gracefully
# after finishing its current bead.  should_stop() checks this file each loop.
cc_cmd_stop() {
    local ipc_dir="$1" log="$2"
    shift 2
    local target
    target=$(cc_flag "--target" "$@") || true
    if [[ -z "$target" ]]; then
        printf '\e[31mstop: --target required  (e.g. stop --target A2)\e[0m\n'
        return 1
    fi
    local pane_id
    pane_id=$(cc_resolve_target "$target" "$ipc_dir") || return 1
    local idx="${target#A}"

    # Per-agent stop file — checked by should_stop() in the worker loop
    touch "${ipc_dir}/stop-A${idx}"
    # C-c wakes a blocking agent/read call so the stop file is seen sooner
    tmux send-keys -t "$pane_id" C-c 2>/dev/null || true

    printf '%s|0|INFO|C&C: graceful stop → %s (%s)\n' \
        "$(date +%H:%M:%S)" "$target" "$pane_id" >> "$log"
    printf '\e[33mGraceful stop sent to %s (%s) — worker exits after current bead\e[0m\n' "$target" "$pane_id"
}

# kill --target A3
# Hard-kills the pane process via respawn-pane -k, then installs a read
# placeholder so the window layout grid is preserved.
cc_cmd_kill() {
    local ipc_dir="$1" log="$2"
    shift 2
    local target
    target=$(cc_flag "--target" "$@") || true
    if [[ -z "$target" ]]; then
        printf '\e[31mkill: --target required  (e.g. kill --target A3)\e[0m\n'
        return 1
    fi
    local pane_id
    pane_id=$(cc_resolve_target "$target" "$ipc_dir") || return 1

    # respawn-pane -k hard-kills and replaces with a placeholder — layout intact
    local placeholder="printf '\033[31m[${target} killed by C&C]\033[0m\n'; printf '\033[90mRun: run --target ${target} to respawn an agent here\033[0m\n'; read -r _"
    if tmux respawn-pane -k -t "$pane_id" "$placeholder" 2>/dev/null; then
        printf '%s|0|INFO|C&C: hard-killed %s (%s)\n' \
            "$(date +%H:%M:%S)" "$target" "$pane_id" >> "$log"
        printf '\e[31mHard-killed %s (%s) — layout preserved\e[0m\n' "$target" "$pane_id"
    else
        printf '\e[31mFailed to kill %s (%s) — pane may not exist\e[0m\n' "$target" "$pane_id"
    fi
}

# help
# Writes a formatted help table to the event log so it appears in the dashboard.
cc_cmd_help() {
    local log="$1"
    local ts; ts=$(date +%H:%M:%S)
    {
        printf '%s|0|INFO|─────────────── C&C Slash Commands ─────────────\n' "$ts"
        printf '%s|0|INFO|  /go                  Run one agent on next bead\n' "$ts"
        printf '%s|0|INFO|  /start               Interactive launch wizard\n' "$ts"
        printf '%s|0|INFO|  /agent               Pick and persist default agent\n' "$ts"
        printf '%s|0|INFO|  /model               Pick and persist default model\n' "$ts"
        printf '%s|0|INFO|  /beads               Show kanban-style bead board\n' "$ts"
        printf '%s|0|INFO|  /bead                Pick bead then action menu\n' "$ts"
        printf '%s|0|INFO|  /prune               Prune merged local/remote branches\n' "$ts"
        printf '%s|0|INFO|  /review              Run one review agent on open agent PRs\n' "$ts"
        printf '%s|0|INFO|  /help                Print this help\n' "$ts"
        printf '%s|0|INFO|  /exit or /quit       Kill whole tmux session and return\n' "$ts"
        printf '%s|0|INFO|\n' "$ts"
        printf '%s|0|INFO|Legacy commands (still supported):\n' "$ts"
        printf '%s|0|INFO|  run  --target A1 [--agent X] [--model Y]  Respawn agent in pane\n' "$ts"
        printf '%s|0|INFO|         Extra abr flags (e.g. --loop-5) are forwarded.\n' "$ts"
        printf '%s|0|INFO|  stop  --target A2     Graceful stop (finishes current bead)\n' "$ts"
        printf '%s|0|INFO|  kill  --target A3     Hard-kill pane (layout preserved)\n' "$ts"
        printf '%s|0|INFO|  status                Show pane→ID map and liveness\n' "$ts"
        printf '%s|0|INFO|  help                  Print this message in the dashboard\n' "$ts"
        printf '%s|0|INFO|  exit / quit           Kill whole tmux session and return\n' "$ts"
        printf '%s|0|INFO|────────────────────────────────────────────────\n' "$ts"
    } >> "$log"
    printf '\e[90m(Help text sent to dashboard above)\e[0m\n'
}

# status
# Writes a pane map and liveness table to the event log.
cc_cmd_status() {
    local ipc_dir="$1" log="$2" num_workers="$3"
    local ts; ts=$(date +%H:%M:%S)
    local session
    session=$(tmux display-message -p '#{session_name}' 2>/dev/null || echo "")
    printf '%s|0|INFO|──────────── Pane Status ─────────────\n' "$ts" >> "$log"
    for (( i=1; i<=num_workers; i++ )); do
        local pane_file="${ipc_dir}/pane-A${i}"
        if [[ -f "$pane_file" ]]; then
            local pane_id; pane_id=$(<"$pane_file")
            local alive="dead"
            if [[ -n "$session" ]] && \
               tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | grep -qxF "$pane_id"; then
                alive="alive"
            fi
            printf '%s|0|INFO|  A%d → %s  [%s]\n' "$ts" "$i" "$pane_id" "$alive" >> "$log"
        else
            printf '%s|0|INFO|  A%d → (not registered yet)\n' "$ts" "$i" >> "$log"
        fi
    done
    printf '%s|0|INFO|──────────────────────────────────────\n' "$ts" >> "$log"
    printf '\e[90m(Status sent to dashboard)\e[0m\n'
}

# --- Package manager detection ------------------------------------------------

detect_pkg_manager() {
    if [[ -f "${REPO_ROOT}/bun.lockb" ]] || [[ -f "${REPO_ROOT}/bun.lock" ]]; then
        echo "bun"
    elif [[ -f "${REPO_ROOT}/pnpm-lock.yaml" ]]; then
        echo "pnpm"
    elif [[ -f "${REPO_ROOT}/yarn.lock" ]]; then
        echo "yarn"
    elif [[ -f "${REPO_ROOT}/package-lock.json" ]] || [[ -f "${REPO_ROOT}/package.json" ]]; then
        echo "npm"
    elif [[ -f "${REPO_ROOT}/Gemfile.lock" ]]; then
        echo "bundle"
    elif [[ -f "${REPO_ROOT}/requirements.txt" ]] || [[ -f "${REPO_ROOT}/pyproject.toml" ]]; then
        echo "pip"
    elif [[ -f "${REPO_ROOT}/go.mod" ]]; then
        echo "go"
    elif [[ -f "${REPO_ROOT}/Cargo.toml" ]]; then
        echo "cargo"
    else
        echo ""
    fi
}

install_deps() {
    local wt_path="$1"
    local pkg_mgr
    pkg_mgr=$(detect_pkg_manager)

    if [[ -z "$pkg_mgr" ]]; then
        log "No recognized package manager — skipping dependency install."
        return 0
    fi

    log "Installing dependencies ($pkg_mgr)..."
    case "$pkg_mgr" in
        npm)    (cd "$wt_path" && npm install --ignore-scripts &>/dev/null && npm rebuild &>/dev/null) || true ;;
        pnpm)   (cd "$wt_path" && pnpm install --ignore-scripts &>/dev/null && pnpm rebuild &>/dev/null) || true ;;
        yarn)   (cd "$wt_path" && yarn install --ignore-scripts &>/dev/null) || true ;;
        bun)    (cd "$wt_path" && bun install --ignore-scripts &>/dev/null) || true ;;
        bundle) (cd "$wt_path" && bundle install --quiet &>/dev/null) || true ;;
        pip)
            if [[ -f "${wt_path}/pyproject.toml" ]]; then
                (cd "$wt_path" && pip install -e . --quiet &>/dev/null) || true
            elif [[ -f "${wt_path}/requirements.txt" ]]; then
                (cd "$wt_path" && pip install -r requirements.txt --quiet &>/dev/null) || true
            fi
            ;;
        go)     (cd "$wt_path" && go mod download &>/dev/null) || true ;;
        cargo)  (cd "$wt_path" && cargo fetch --quiet &>/dev/null) || true ;;
    esac
}

# --- Env file copying ---------------------------------------------------------

copy_env_files() {
    local wt_path="$1"
    local copied=0

    for envfile in "${REPO_ROOT}"/.env*; do
        [[ -f "$envfile" ]] || continue
        local basename
        basename="$(basename "$envfile")"
        case "$basename" in
            *.example|*.sample) continue ;;
        esac
        cp -f "$envfile" "${wt_path}/${basename}"
        copied=$((copied + 1))
    done

    for cfg in .dev.vars .secrets .npmrc.local; do
        if [[ -f "${REPO_ROOT}/${cfg}" ]]; then
            cp -f "${REPO_ROOT}/${cfg}" "${wt_path}/${cfg}"
            copied=$((copied + 1))
        fi
    done

    [[ $copied -gt 0 ]] && log "Copied $copied env/config file(s) to worktree."
}

# --- Quality gate detection ---------------------------------------------------

detect_quality_commands() {
    local cmds=""
    local pkg_mgr
    pkg_mgr=$(detect_pkg_manager)

    case "$pkg_mgr" in
        npm|pnpm|yarn|bun)
            if [[ -f "${REPO_ROOT}/package.json" ]]; then
                local scripts
                scripts=$(python3 -c "
import json, sys
try:
    pkg = json.load(open('${REPO_ROOT}/package.json'))
    for s in pkg.get('scripts', {}):
        print(s)
except: pass
" 2>/dev/null || true)
                local run="${pkg_mgr} run"
                [[ "$pkg_mgr" == "npm" ]] && run="npm run"
                echo "$scripts" | grep -q "^lint$" && cmds+="   - `${run} lint`\n"
                echo "$scripts" | grep -q "^typecheck$" && cmds+="   - `${run} typecheck`\n"
                echo "$scripts" | grep -q "^test$" && cmds+="   - `${run} test`\n"
                echo "$scripts" | grep -q "^build$" && cmds+="   - `${run} build`\n"
                if [[ -f "${REPO_ROOT}/tsconfig.json" ]] && ! echo "$scripts" | grep -q "^typecheck$"; then
                    cmds+="   - `npx tsc --noEmit` (typecheck)\n"
                fi
            fi
            ;;
        bundle)
            [[ -f "${REPO_ROOT}/Rakefile" ]] && cmds+="   - `bundle exec rake`\n" ;;
        pip)
            cmds+="   - Run any linters/tests configured in the project\n" ;;
        go)
            cmds+="   - `go vet ./...`\n"
            cmds+="   - `go test ./...`\n" ;;
        cargo)
            cmds+="   - `cargo check`\n"
            cmds+="   - `cargo test`\n" ;;
    esac

    if [[ -z "$cmds" ]]; then
        cmds="   - Run any linters, tests, or build checks configured in the project\n"
    fi

    printf '%b' "$cmds"
}

# --- Model resolution ---------------------------------------------------------
#
# Resolves short model names + effort suffixes into full model names and flags.
# Sets global: MODEL_RESOLVED (full model name), EFFORT_RESOLVED (effort level)

resolve_model_and_effort() {
    local agent="$1"
    local short="$2"

    MODEL_RESOLVED=""
    EFFORT_RESOLVED=""

    if [[ -z "$short" ]]; then
        return 0
    fi

    # Extract effort suffix (only active for copilot --effort flag)
    local base="$short"
    case "$short" in
        *-xh) EFFORT_RESOLVED="xhigh";  base="${short%-xh}" ;;
        *-h)  EFFORT_RESOLVED="high";   base="${short%-h}" ;;
        *-m)  EFFORT_RESOLVED="medium"; base="${short%-m}" ;;
        *-l)  EFFORT_RESOLVED="low";    base="${short%-l}" ;;
    esac

    # Resolve short name → full model name per agent
    case "$agent" in
        copilot)
            case "$base" in
                # Claude
                sonnet4|sonnet-4)       MODEL_RESOLVED="claude-sonnet-4" ;;
                sonnet45|sonnet-45)     MODEL_RESOLVED="claude-sonnet-4.5" ;;
                sonnet46|sonnet-46)     MODEL_RESOLVED="claude-sonnet-4.6" ;;
                opus45|opus-45)         MODEL_RESOLVED="claude-opus-4.5" ;;
                opus46|opus-46)         MODEL_RESOLVED="claude-opus-4.6" ;;
                haiku)                  MODEL_RESOLVED="claude-haiku-4.5" ;;
                # GPT
                gpt41|gpt-41)           MODEL_RESOLVED="gpt-4.1" ;;
                gpt5m|gpt-5m)           MODEL_RESOLVED="gpt-5-mini" ;;
                gpt52|gpt-52)           MODEL_RESOLVED="gpt-5.2" ;;
                gpt52c|gpt-52c)         MODEL_RESOLVED="gpt-5.2-codex" ;;
                gpt53c|gpt-53c)         MODEL_RESOLVED="gpt-5.3-codex" ;;
                gpt54|gpt-54)           MODEL_RESOLVED="gpt-5.4" ;;
                gpt54m|gpt-54m)         MODEL_RESOLVED="gpt-5.4-mini" ;;
                # Gemini
                gem25p|gem-25p)         MODEL_RESOLVED="gemini-2.5-pro" ;;
                gem3f|gem-3f)           MODEL_RESOLVED="gemini-3-flash-preview" ;;
                gem31p|gem-31p)         MODEL_RESOLVED="gemini-3.1-pro-preview" ;;
                # Other
                grok)                   MODEL_RESOLVED="grok-code-fast-1" ;;
                raptor)                 MODEL_RESOLVED="raptor-mini" ;;
                goldeneye)              MODEL_RESOLVED="goldeneye" ;;
                *)                      MODEL_RESOLVED="$base" ;;  # pass-through
            esac ;;
        claude)
            case "$base" in
                sonnet4|sonnet-4)       MODEL_RESOLVED="claude-sonnet-4-0" ;;
                sonnet45|sonnet-45)     MODEL_RESOLVED="claude-sonnet-4-5" ;;
                sonnet46|sonnet-46)     MODEL_RESOLVED="claude-sonnet-4-6" ;;
                opus45|opus-45)         MODEL_RESOLVED="claude-opus-4-5" ;;
                opus46|opus-46)         MODEL_RESOLVED="claude-opus-4-6" ;;
                haiku)                  MODEL_RESOLVED="claude-haiku-4-5" ;;
                *)                      MODEL_RESOLVED="$base" ;;
            esac ;;
        gemini)
            case "$base" in
                25-pro)                 MODEL_RESOLVED="gemini-2.5-pro" ;;
                25-flash)               MODEL_RESOLVED="gemini-2.5-flash" ;;
                2-flash)                MODEL_RESOLVED="gemini-2.0-flash" ;;
                3-flash|gem3f|gem-3f)   MODEL_RESOLVED="gemini-3-flash-preview" ;;
                31-pro|gem31p|gem-31p)  MODEL_RESOLVED="gemini-3.1-pro-preview" ;;
                25-pro-p|gem25p|gem-25p) MODEL_RESOLVED="gemini-2.5-pro" ;;
                *)                      MODEL_RESOLVED="$base" ;;
            esac ;;
        codex)
            case "$base" in
                gpt54|gpt-54)           MODEL_RESOLVED="gpt-5.4" ;;
                gpt54m|gpt-54m)         MODEL_RESOLVED="gpt-5.4-mini" ;;
                gpt53c|gpt-53c)         MODEL_RESOLVED="gpt-5.3-codex" ;;
                gpt53cs|gpt-53cs)       MODEL_RESOLVED="gpt-5.3-codex-spark" ;;
                gpt52|gpt-52)           MODEL_RESOLVED="gpt-5.2" ;;
                gpt41|gpt-41)           MODEL_RESOLVED="gpt-4.1" ;;
                gpt41m|gpt-41m)         MODEL_RESOLVED="gpt-4.1-mini" ;;
                gpt41n|gpt-41n)         MODEL_RESOLVED="gpt-4.1-nano" ;;
                o4m)                    MODEL_RESOLVED="o4-mini" ;;
                o3m)                    MODEL_RESOLVED="o3-mini" ;;
                *)                      MODEL_RESOLVED="$base" ;;  # pass-through
            esac ;;
        *)
            MODEL_RESOLVED="$base" ;;
    esac
}

# --- Agent prompt builder -----------------------------------------------------

build_agent_prompt() {
    local bead_id="$1"
    local quality_cmds
    quality_cmds=$(detect_quality_commands)

    cat <<PROMPT
You are an autonomous AI coding agent working on a single task in an isolated git worktree.

## Your Task
Work on bead: $bead_id

## Workflow (follow EXACTLY)

1. Run \`bd prime\` to load the full beads workflow context
2. Run \`bd show $bead_id\` to understand the task details and dependencies
3. Verify the bead is claimed (already done by the launcher). If not, run \`bd update $bead_id --claim\`
4. **Before making any changes**, establish the baseline lint/quality status:
   - Capture current lint state: \`${quality_cmds}\` (redirect to file for later comparison)
   - Note any existing failures in the baseline for context
5. Implement the changes required by the bead
6. Run quality gates if code was changed:
${quality_cmds}7. **Report lint findings**: After implementing changes, record both:
   - Any NEW lint errors in files you changed (these are blocking and must be fixed)
   - Baseline lint errors that existed before (informational — not blocking for this bead)
   - If new errors exist in your changed files, fix them before moving forward
8. Complete the session close protocol:
   a. \`git add <changed files>\`
   b. \`git commit -m "feat($bead_id): <concise description>"\`
   c. \`git push --set-upstream origin \$(git branch --show-current)\`
   d. \`bd close $bead_id\`
   e. \`bd dolt push\`
   f. \`git status\` — must show "up to date with origin"

   **Important**: Always push the git branch (step c) BEFORE closing the bead (step d). The PR is created by the launcher after you exit — it needs the branch on the remote.

## Tool Preferences
- **Always prefer CLI tools over MCP tools** when both can accomplish the task. CLI tools are faster and consume less context window. Only fall back to MCP tools when the CLI tool cannot get the job done.
- **Supabase**: If the bead involves Supabase, read the \`supabase\` skill documentation before running any \`supabase\` commands. Do NOT run \`supabase\` commands speculatively or as a setup step — only run them when explicitly required by the bead and after reading the skill rules. The online (remote) Supabase database is always the source of truth; local migration files may be stale.
- **iOS/macOS builds**: If the bead involves building or testing iOS/macOS code, prefer \`xcodebuild\` (the standard Apple CLI) over MCP tools when both can accomplish the task. Read the \`xcodebuildmcp-cli\` skill documentation before running any build commands.

## Rules
- Work ONLY on bead $bead_id — do not touch other beads
- Do NOT modify files unrelated to this bead
- If the bead is blocked or unclear, run \`bd update $bead_id --notes="<your concern>"\` and exit
- If you create follow-up work, use \`bd create\` to file new beads
- Use non-interactive flags: cp -f, mv -f, rm -f
- Do NOT use interactive editors (vim, nano, etc.)
- NEVER skip the git push step — work is not done until pushed
- **Lint gate policy**: You must fix any NEW lint errors in files you changed. Pre-existing baseline errors are acceptable (separate lint-debt bead).
PROMPT
}

# --- Cleanup on exit ----------------------------------------------------------

cleanup_worktree() {
    local wt_path="$1"
    local branch="${2:-}"
    local pr_local_ref="${3:-}"
    if [[ -d "$wt_path" ]]; then
        log "Cleaning up worktree: $wt_path"
        cd "$REPO_ROOT"
        bd_locked worktree remove "$wt_path" --force 2>/dev/null || \
            git worktree remove "$wt_path" --force 2>/dev/null || true
        git worktree prune 2>/dev/null || true
    fi

    if [[ -n "$branch" ]] && git show-ref --verify --quiet "refs/heads/$branch"; then
        if git branch -D "$branch" &>/dev/null; then
            log "Deleted local branch: $branch"
        else
            log "Could not delete local branch: $branch"
        fi
    fi

    # Clean up any locally-fetched PR review ref (pull/N/head fetched for fork PRs)
    if [[ -n "$pr_local_ref" ]] && git show-ref --verify --quiet "refs/heads/$pr_local_ref"; then
        git branch -D "$pr_local_ref" 2>/dev/null && log "Deleted PR review ref: $pr_local_ref" || true
    fi
}

prune_local_branches() {
    cd "$REPO_ROOT"

    local default_branch current_branch
    local deleted=0 kept=0

    default_branch=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##')
    [[ -z "$default_branch" ]] && default_branch="main"
    current_branch=$(git branch --show-current 2>/dev/null || echo "")

    log "Pruning merged local agent branches against origin/${default_branch}..."
    # Fetch all branches and prune stale remote-tracking refs (including origin/agent/*)
    git fetch origin --prune 2>/dev/null || true

    local branch
    while IFS= read -r branch; do
        [[ -z "$branch" ]] && continue

        if [[ "$branch" == "$current_branch" ]]; then
            log "Keeping checked-out branch: $branch"
            kept=$((kept + 1))
            continue
        fi

        # Delete if commits are merged into default branch (fast-forward) OR
        # remote branch is gone (squash/rebase merge deletes remote but changes SHA)
        if git merge-base --is-ancestor "$branch" "origin/$default_branch" 2>/dev/null || \
           ! git show-ref --verify --quiet "refs/remotes/origin/$branch"; then
            if git branch -D "$branch" &>/dev/null; then
                log "Deleted local branch: $branch"
                deleted=$((deleted + 1))
            else
                log "Could not delete local branch: $branch"
                kept=$((kept + 1))
            fi
        else
            log "Keeping unmerged branch: $branch"
            kept=$((kept + 1))
        fi
    done < <(git for-each-ref --format='%(refname:short)' refs/heads/agent)

    # Also clean up any leftover pr-* local refs (local-only fetch refs, always safe to force-delete)
    # Matches: pr-review-N (current naming), and legacy patterns like pr-N, pr-N-head, pr-N-review
    local ref
    while IFS= read -r ref; do
        [[ -z "$ref" ]] && continue
        if git branch -D "$ref" &>/dev/null; then
            log "Deleted PR review ref: $ref"
            deleted=$((deleted + 1))
        fi
    done < <(git for-each-ref --format='%(refname:short)' 'refs/heads/pr-*')

    log "Prune complete. Deleted: $deleted  Kept: $kept"
}

prune_remote_branches() {
    cd "$REPO_ROOT"

    local default_branch
    local deleted=0 kept=0 failed=0

    default_branch=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##')
    [[ -z "$default_branch" ]] && default_branch="main"

    log "Refreshing remote refs from origin..."
    git fetch origin --prune 2>/dev/null || true

    local remote_agent_branches remote_pr_branches
    remote_agent_branches=$(git for-each-ref --format='%(refname:short)' refs/remotes/origin/agent | sed 's#^origin/##')
    remote_pr_branches=$(git for-each-ref --format='%(refname:short)' 'refs/remotes/origin/pr' | sed 's#^origin/##')

    if [[ -z "$remote_agent_branches" && -z "$remote_pr_branches" ]]; then
        log "No remote agent/* or pr/* branches found on origin."
        return 0
    fi

    log "Pruning merged remote agent/* and pr/* branches against origin/${default_branch}..."
    local branch
    while IFS= read -r branch; do
        [[ -z "$branch" ]] && continue

        if git merge-base --is-ancestor "origin/$branch" "origin/$default_branch" 2>/dev/null || \
           ! git show-ref --verify --quiet "refs/remotes/origin/$branch"; then
            if [[ "$DRY_RUN" == "true" ]]; then
                log "[DRY RUN] Would delete remote branch: $branch"
                deleted=$((deleted + 1))
            elif git push origin --delete "$branch" &>/dev/null; then
                log "Deleted remote branch: $branch"
                deleted=$((deleted + 1))
            else
                log "Could not delete remote branch: $branch"
                failed=$((failed + 1))
            fi
        else
            log "Keeping unmerged remote branch: $branch"
            kept=$((kept + 1))
        fi
    done <<< "$(printf '%s\n' $remote_agent_branches $remote_pr_branches)"

    log "Remote prune complete. Deleted: $deleted  Kept: $kept  Failed: $failed"
}

# --- Run one bead (worktree → agent → PR → cleanup) --------------------------

run_one_bead() {
    local bead_id="$1"
    local branch wt_path

    branch=$(sanitize_branch "$bead_id")
    wt_path="${WORKTREE_BASE}/${branch}"

    log "=== Starting agent for bead: $bead_id ==="
    log "Branch: $branch | Worktree: $wt_path"

    if [[ "$DRY_RUN" == "true" ]]; then
        ipc_event "CLAIM" "Bead $bead_id claimed"
        log "[DRY RUN] Would create worktree and launch $AGENT_TOOL for $bead_id"
        return 0
    fi

    # Guard: if the worktree already exists another agent beat us here.
    # This can happen during parallel runs when two agents both successfully
    # claim the same bead (DB sync lag) and the second reaches run_one_bead
    # after the first has already created the worktree.
    if [[ -d "$wt_path" ]]; then
        logr "Worktree $wt_path already exists — bead $bead_id is being handled by another agent. Aborting session."
        return 1
    fi

    # Only emit CLAIM after passing the worktree guard — an agent that loses the
    # race and is blocked above never actually claimed the bead, so it must not
    # inflate the orchestrator's claim count.
    ipc_event "CLAIM" "Bead $bead_id claimed"

    mkdir -p "$(dirname "$wt_path")"

    cd "$REPO_ROOT"
    log "Creating worktree..."
    bd_locked worktree create "$wt_path" --branch "$branch" 2>&1 | while read -r line; do
        log "  $line"
    done

    copy_env_files "$wt_path"
    install_deps "$wt_path"

    trap "cleanup_worktree '$wt_path' '$branch'" EXIT

    local prompt
    prompt=$(build_agent_prompt "$bead_id")

    log "Launching $AGENT_TOOL agent..."
    ipc_event "START" "Launching $AGENT_TOOL for bead $bead_id"

    # Resolve model and effort from --model flag
    resolve_model_and_effort "$AGENT_TOOL" "$MODEL"

    case "$AGENT_TOOL" in
        copilot)
            local cp_model="${MODEL_RESOLVED:-claude-sonnet-4.6}"
            local cp_effort="${EFFORT_RESOLVED:-high}"
            (cd "$wt_path" && "$COPILOT_CLI" \
                --prompt "$prompt" \
                --model "$cp_model" \
                --effort "$cp_effort" \
                --allow-all \
                --autopilot)
            ;;
        claude)
            local cl_args=(--prompt "$prompt" --allowedTools "Bash,Read,Write,Grep,Glob" --yes)
            [[ -n "$MODEL_RESOLVED" ]] && cl_args+=(--model "$MODEL_RESOLVED")
            (cd "$wt_path" && claude "${cl_args[@]}")
            ;;
        gemini)
            local gm_args=(--prompt "$prompt" --approval-mode=yolo)
            [[ -n "$MODEL_RESOLVED" ]] && gm_args+=(--model "$MODEL_RESOLVED")
            (cd "$wt_path" && gemini "${gm_args[@]}") ;;
        codex)
            local cx_args=(exec --full-auto)
            [[ -n "$MODEL_RESOLVED" ]] && cx_args+=(--model "$MODEL_RESOLVED")
            [[ -n "$EFFORT_RESOLVED" ]] && cx_args+=(-c "model_reasoning_effort=\"$EFFORT_RESOLVED\"")
            cx_args+=("$prompt")
            (cd "$wt_path" && codex "${cx_args[@]}")
            ;;
        *)
            logr "Unknown agent tool: $AGENT_TOOL (valid: copilot, claude, gemini, codex)"
            return 1
            ;;
    esac

    local exit_code=$?

    # Create PR if agent pushed successfully
    if [[ $exit_code -eq 0 ]] && command -v gh &>/dev/null; then
        local remote_branch
        remote_branch=$(git -C "$wt_path" rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null || echo "")
        if [[ -z "$remote_branch" ]]; then
            # Fallback: agent may have pushed without --set-upstream; verify via ls-remote
            if git -C "$wt_path" ls-remote --exit-code --heads origin "$branch" &>/dev/null; then
                remote_branch="origin/$branch"
                log "Branch $branch found on origin (no local tracking ref — agent pushed without -u)."
            else
                # Safety net: push the branch ourselves so the PR can be created
                log "Branch $branch not on remote — pushing before PR creation..."
                local push_out push_exit
                push_out=$(git -C "$wt_path" push --set-upstream origin "$branch" 2>&1)
                push_exit=$?
                while IFS= read -r line; do log "  $line"; done <<< "$push_out"
                if [[ $push_exit -eq 0 ]]; then
                    remote_branch="origin/$branch"
                    log "Branch pushed by abr safety net."
                else
                    logr "Push failed (exit=$push_exit) — cannot create PR. Resetting bead to 'open' for retry."
                    bd_locked update "$bead_id" --status open \
                        --notes "abr: agent did not push; abr safety-net push also failed" 2>/dev/null || true
                    bd_locked dolt push 2>/dev/null || true
                    exit_code=1
                fi
            fi
        fi
        if [[ $exit_code -eq 0 && -n "$remote_branch" ]]; then
            log "Creating PR..."
            local pr_title
            pr_title=$(bd_locked show "$bead_id" --json 2>/dev/null \
                | python3 -c "import sys,json; print(json.load(sys.stdin).get('title','Work on $bead_id'))" 2>/dev/null \
                || echo "Work on $bead_id")
            local pr_out pr_exit
            pr_out=$(cd "$wt_path" && gh pr create \
                --title "feat($bead_id): $pr_title" \
                --body "Automated PR for bead \`$bead_id\`. Created by abr." \
                --base main 2>&1)
            pr_exit=$?
            while IFS= read -r line; do log "  $line"; done <<< "$pr_out"
            if [[ $pr_exit -eq 0 ]]; then
                log "PR created."
                ipc_event "PR" "PR created for bead $bead_id"
            elif echo "$pr_out" | grep -qi "already exists"; then
                # The agent created the PR during its own session.
                # Extract the URL from the error output and still count it as a PR.
                local existing_url
                existing_url=$(echo "$pr_out" | grep -o 'https://[^[:space:]]*' | tail -1)
                log "PR already exists (agent created it): ${existing_url:-see GitHub}"
                ipc_event "PR" "PR already existed for bead $bead_id${existing_url:+ ($existing_url)}"
            else
                logr "PR creation failed (exit=$pr_exit) — resetting bead to 'open' for retry."
                local pr_note="${pr_out:0:200}"
                bd_locked update "$bead_id" --status open \
                    --notes "abr: PR creation failed: $pr_note" 2>/dev/null || true
                bd_locked dolt push 2>/dev/null || true
                exit_code=1
            fi
        fi
    else
        [[ $exit_code -ne 0 ]] && logr "Agent exited with code $exit_code"
    fi

    # Safety net: if the bead is still in-progress (agent didn't run `bd close`,
    # PR creation failed, or the agent crashed), reset it to 'open' so it can
    # be retried rather than staying stuck forever.
    if [[ $exit_code -ne 0 ]]; then
        local current_bead_status
        current_bead_status=$(bd_locked show "$bead_id" --json 2>/dev/null \
            | python3 -c "import sys,json; print(json.load(sys.stdin).get('status',''))" 2>/dev/null \
            || echo "")
        if [[ "$current_bead_status" == "in_progress" || "$current_bead_status" == "in-progress" ]]; then
            logr "Bead $bead_id still in-progress after failure — resetting to 'open' for retry."
            bd_locked update "$bead_id" --status open 2>/dev/null || true
            bd_locked dolt push 2>/dev/null || true
        fi
    fi

    trap - EXIT
    cleanup_worktree "$wt_path" "$branch"

    if [[ $exit_code -eq 0 ]]; then
        ipc_event "DONE" "Bead $bead_id finished"
    else
        ipc_event "ERROR" "Bead $bead_id failed (exit=$exit_code)"
    fi
    log "=== Finished bead: $bead_id (exit=$exit_code) ==="
    return $exit_code
}

# --- Loop runner (re-invokes script for each bead = fresh session) ------------

run_loop() {
    local limit_msg=""
    [[ "$LOOP_MAX" -gt 0 ]] && limit_msg=" (max $LOOP_MAX)"
    log "=== Loop mode: fresh session per bead${limit_msg}, Ctrl+C to stop gracefully ==="
    log "PID: $$  |  Or: touch $STOP_FILE  |  Or: kill -USR1 $$"

    # Clean up any stale stop file from a previous run
    rm -f "$STOP_FILE"

    local script_path
    script_path="$(command -v abr 2>/dev/null || echo "$0")"
    local iteration=0
    local completed=0

    while true; do
        iteration=$((iteration + 1))

        # Check graceful stop before picking next bead
        if should_stop; then
            log "Graceful stop: exiting after $completed bead(s)."
            break
        fi

        # Check iteration limit
        if [[ "$LOOP_MAX" -gt 0 && $completed -ge $LOOP_MAX ]]; then
            log "Loop limit reached ($LOOP_MAX). Finished $completed bead(s)."
            break
        fi

        # Sync beads: pull only when another agent has pushed since we last
        # pulled. In solo mode (no last_push signal) we always pull.
        if ipc_needs_pull; then
            bd_locked dolt pull 2>/dev/null || true
            ipc_record_pull
        fi

        local bead_id
        bead_id=$(pick_next_bead)

        if [[ -z "$bead_id" ]]; then
            log "No more ready beads. Loop finished after $completed bead(s)."
            break
        fi

        log "Loop iteration $iteration (completed $completed${limit_msg}): picked bead $bead_id"

        if [[ "$DRY_RUN" == "true" ]]; then
            log "[DRY RUN] Would spawn fresh session for $bead_id, then pick next..."
            break
        fi

        # IPC pre-flight: check if a local pane has already broadcasted a claim
        # for this bead. This fires before the dolt push completes and before
        # the worktree directory is created, closing the earliest race window.
        if ipc_is_claimed "$bead_id"; then
            log "Bead $bead_id already claimed by a local agent (IPC) — skipping."
            sleep $(( (RANDOM % 3) + 2 ))
            continue
        fi

        # Worktree pre-flight: check worktree existence BEFORE claiming. This is a
        # filesystem check (instant, no DB sync lag) and catches the case where
        # a parallel agent on this machine already claimed+started this bead
        # but hasn't pushed the DB update yet, so dolt pull still shows it ready.
        local branch wt_check_path
        branch=$(sanitize_branch "$bead_id")
        wt_check_path="${WORKTREE_BASE}/${branch}"
        if [[ -d "$wt_check_path" ]]; then
            log "Bead $bead_id worktree already exists (another agent is working on it) — skipping."
            # Force a fresh sync so next iteration sees updated bead state
            bd_locked dolt pull 2>/dev/null || true
            sleep $(( (RANDOM % 4) + 3 ))
            continue
        fi

        # Claim from main repo BEFORE spawning subprocess so parallel
        # loops see the bead as taken on their next pick_next_bead call.
        if ! claim_bead "$bead_id"; then
            log "Bead $bead_id already claimed — syncing and skipping to next."
            # Extra pull + longer backoff: give the claiming agent time to push
            # so that our next pick_next_bead no longer sees this bead as ready.
            bd_locked dolt pull 2>/dev/null || true
            ipc_record_pull
            sleep $(( (RANDOM % 4) + 3 ))
            continue
        fi

        # Broadcast the claim over IPC so other loop panes skip this bead
        # immediately, without waiting for the dolt push to propagate.
        ipc_signal_claimed "$bead_id"

        # Re-invoke this script as a subprocess — completely fresh session.
        # ABR_LOOP_CHILD=1 tells the child not to emit an EXIT event; the
        # parent run_loop() emits a single EXIT when the whole loop is done.
        local loop_invoke_flags=(--bead "$bead_id" --agent "$AGENT_TOOL")
        [[ -n "$MODEL" ]] && loop_invoke_flags+=(--model "$MODEL")
        local child_exit=0
        ABR_LOOP_CHILD=1 "$script_path" "${loop_invoke_flags[@]}" || child_exit=$?
        completed=$((completed + 1))
        ipc_clear_claim "$bead_id"  # Release IPC claim so other panes know it's done

        local status_word="ok"
        [[ $child_exit -ne 0 ]] && status_word="exit=$child_exit"
        log "Loop: bead $bead_id session closed ($completed processed, $status_word). Picking next..."
        sleep 2  # Brief pause between sessions
    done

    ipc_event "EXIT" "Worker loop done ($completed bead(s) processed)"
    ipc_cleanup_self  # Remove per-process pull stamp
    rm -f "$STOP_FILE"
}

# --- Tmux launcher (parallel panes) ------------------------------------------

launch_tmux() {
    if ! command -v tmux &>/dev/null; then
        logr "tmux is required for --parallel. Install with: brew install tmux"
        exit 1
    fi

    local script_path
    script_path="$(command -v abr 2>/dev/null || echo "$0")"

    # Build the flags each pane should use
    local agent_model_flags="--agent '$AGENT_TOOL'"
    [[ -n "$MODEL" ]] && agent_model_flags+=" --model '$MODEL'"
    local pane_flags="$agent_model_flags"
    if [[ "$LOOP_MODE" == "true" ]]; then
        if [[ "$LOOP_MAX" -gt 0 ]]; then
            pane_flags+=" --loop-${LOOP_MAX}"
        else
            pane_flags+=" --loop"
        fi
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
        local session_exists="no"
        tmux has-session -t "$TMUX_SESSION" 2>/dev/null && session_exists="yes"

        if [[ "$session_exists" == "yes" && "$NEW_TMUX" != "true" ]]; then
            log "[DRY RUN] Would add $PARALLEL pane(s) to existing tmux session '$TMUX_SESSION'"
        elif [[ "$session_exists" == "yes" && "$NEW_TMUX" == "true" ]]; then
            log "[DRY RUN] Would create a new tmux session (existing '$TMUX_SESSION' kept) with $PARALLEL pane(s)"
        else
            log "[DRY RUN] Would create tmux session '$TMUX_SESSION' with $PARALLEL pane(s) + orchestrator"
        fi
        if [[ "$ORCHESTRATOR_MODE" == "true" ]]; then
            log "[DRY RUN] Each worker pane starts idle (no agent command yet)"
        else
            log "[DRY RUN] Each pane runs: abr $pane_flags"
        fi
        if [[ "$LOOP_MODE" == "true" ]]; then
            log "[DRY RUN] Each pane loops with fresh sessions per bead"
        else
            log "[DRY RUN] Each pane works one bead then exits"
        fi
        log ""
        log "[DRY RUN] Ready beads:"
        bd_locked ready 2>/dev/null
        return 0
    fi

    # Check if tmux session already exists
    local session_exists=false
    tmux has-session -t "$TMUX_SESSION" 2>/dev/null && session_exists=true

    if [[ "$session_exists" == "true" && "$NEW_TMUX" == "true" ]]; then
        # Find next available session name (append -2, -3, etc.)
        local base_name="$TMUX_SESSION"
        local suffix=2
        while tmux has-session -t "${base_name}-${suffix}" 2>/dev/null; do
            suffix=$((suffix + 1))
        done
        TMUX_SESSION="${base_name}-${suffix}"
        log "Existing session found. Creating new session: $TMUX_SESSION"
        session_exists=false
    fi

    # Per-session log directory in /tmp; deleted on /exit.
    local ABR_LOG_DIR="/tmp/abr-${TMUX_SESSION}"

    # Build the array of worker commands
    local pane_cmds=()
    if [[ "$ORCHESTRATOR_MODE" == "true" ]]; then
        for (( i=0; i<PARALLEL; i++ )); do
            pane_cmds+=("export ABR_AGENT_IDX=$((i+1)); printf '%s' \"\$TMUX_PANE\" > '${WORKTREE_BASE}/.abr-ipc/pane-A$((i+1))'; printf '\\033[90m[A$((i+1)) idle] Use /go or /start from C&C to launch\\033[0m\\n'; read -r _")
        done
    elif [[ "$LOOP_MODE" == "true" ]]; then
        local loop_flag="--loop"
        [[ "$LOOP_MAX" -gt 0 ]] && loop_flag="--loop-${LOOP_MAX}"
        for (( i=0; i<PARALLEL; i++ )); do
            pane_cmds+=("export ABR_AGENT_IDX=$((i+1)); printf '%s' \"\$TMUX_PANE\" > '${WORKTREE_BASE}/.abr-ipc/pane-A$((i+1))'; tmux pipe-pane -t \"\$TMUX_PANE\" -o \"cat >> '${ABR_LOG_DIR}/agent-A$((i+1)).log'\"; sleep $((i * 3)) && cd '$REPO_ROOT' && '$script_path' $loop_flag $agent_model_flags; echo ''; echo '=== Pane finished. Press Enter to close ==='; read")
        done
    else
        # Non-loop: pre-assign one bead per pane
        local beads_to_run=()
        if [[ -n "$TARGET_BEAD" ]]; then
            beads_to_run+=("$TARGET_BEAD")
        else
            while IFS= read -r bead_id; do
                [[ -n "$bead_id" ]] && beads_to_run+=("$bead_id")
            done < <(pick_n_beads "$PARALLEL")
        fi

        if [[ ${#beads_to_run[@]} -eq 0 ]]; then
            log "No ready beads found. Run 'bd ready' to check status."
            exit 0
        fi

        local total=${#beads_to_run[@]}
        [[ $total -gt $PARALLEL ]] && total=$PARALLEL

        for (( i=0; i<total; i++ )); do
            local bead="${beads_to_run[$i]}"
            pane_cmds+=("export ABR_AGENT_IDX=$((i+1)); printf '%s' \"\$TMUX_PANE\" > '${WORKTREE_BASE}/.abr-ipc/pane-A$((i+1))'; tmux pipe-pane -t \"\$TMUX_PANE\" -o \"cat >> '${ABR_LOG_DIR}/agent-A$((i+1)).log'\"; sleep $((i * 3)) && cd '$REPO_ROOT' && '$script_path' --bead '$bead' $agent_model_flags; echo ''; echo '=== Pane finished. Press Enter to close ==='; read")
        done
    fi

    local total_workers=${#pane_cmds[@]}

    # Existing session: add panes in tiled layout (no new orchestrator)
    if [[ "$session_exists" == "true" ]]; then
        log "Adding $total_workers pane(s) to existing tmux session '$TMUX_SESSION'..."
        for (( i=0; i<total_workers; i++ )); do
            tmux split-window -t "$TMUX_SESSION" "${pane_cmds[$i]}"
            tmux select-layout -t "$TMUX_SESSION" tiled
        done
        tmux select-layout -t "$TMUX_SESSION" tiled
        log "Added $total_workers pane(s) to existing session '$TMUX_SESSION'."
        log "  Attach:  tmux attach -t $TMUX_SESSION"
        if [[ -z "${TMUX:-}" ]]; then
            exec tmux attach -t "$TMUX_SESSION"
        else
            log "(Already inside tmux — switch with: tmux switch -t $TMUX_SESSION)"
        fi
        return 0
    fi

    # New session: build orchestrator + worker layout and init the event log
    mkdir -p "${WORKTREE_BASE}/.abr-ipc"
    mkdir -p "${ABR_LOG_DIR}"
    > "${WORKTREE_BASE}/.abr-ipc/events.log"   # fresh log for this run

    local orch_cmd="cd '$REPO_ROOT' && '$script_path' --internal-orchestrator $total_workers"
    log "Creating tmux session '$TMUX_SESSION' with orchestrator + $total_workers worker pane(s)..."

    # Use the actual terminal width so the session fills the screen.
    local total_cols
    total_cols=$(tput cols 2>/dev/null || echo 220)

    # Build layout around a stable pane ID.
    # Start the session with orchestrator command directly so the first pane stays alive.
    tmux new-session -d -s "$TMUX_SESSION" -x "$total_cols" -y 50 "$orch_cmd"
    tmux rename-window -t "$TMUX_SESSION" "agents"
    local center_pane
    center_pane=$(tmux list-panes -t "$TMUX_SESSION" -F '#{pane_id}' | head -n1)

    if [[ $total_workers -eq 1 ]]; then
        # Layout: orchestrator top, agent bottom
        tmux split-window -v -t "$center_pane" "${pane_cmds[0]}"
    else
        # Layout: left column | orchestrator (center, 250 cols) | right column
        # left gets floor(N/2) agents, right gets ceil(N/2) agents
        local left_total=$(( total_workers / 2 ))
        local right_total=$(( total_workers - left_total ))

        # Create root panes for left and right columns around the center pane.
        local left_root right_root
        left_root=$(tmux split-window -h -b -P -F '#{pane_id}' -t "$center_pane" "${pane_cmds[0]}")
        right_root=$(tmux split-window -h -P -F '#{pane_id}' -t "$center_pane" "${pane_cmds[$left_total]}")

        # Equalize the three main columns, then pin center to 250 cols.
        tmux select-layout -t "$TMUX_SESSION" even-horizontal
        tmux resize-pane -x 250 -t "$center_pane"

        # Fill left column by splitting downward from the current tail pane.
        local left_tail="$left_root"
        for (( i=1; i<left_total; i++ )); do
            left_tail=$(tmux split-window -v -P -F '#{pane_id}' -t "$left_tail" "${pane_cmds[$i]}")
        done

        # Fill right column by splitting downward from the current tail pane.
        local right_tail="$right_root"
        for (( i=1; i<right_total; i++ )); do
            right_tail=$(tmux split-window -v -P -F '#{pane_id}' -t "$right_tail" "${pane_cmds[$(( left_total + i ))]}")
        done
    fi

    log "Tmux session: $TMUX_SESSION"
    if [[ "$ORCHESTRATOR_MODE" == "true" ]]; then
        log "Mode: orchestrator with idle worker panes"
    elif [[ "$LOOP_MODE" == "true" ]]; then
        log "Mode: each pane loops (fresh session per bead)"
    else
        log "Mode: each pane works one bead then exits"
    fi
    log ""
    log "  Attach:  tmux attach -t $TMUX_SESSION"
    log "  Kill:    tmux kill-session -t $TMUX_SESSION"
    log "  Logs:    ${ABR_LOG_DIR}/  (deleted on /exit)"
    log ""

    if [[ -z "${TMUX:-}" ]]; then
        exec tmux attach -t "$TMUX_SESSION"
    else
        log "(Already inside tmux — switch with: tmux switch -t $TMUX_SESSION)"
    fi
}

# --- Conflict resolution prompt builder ----------------------------------------

build_conflict_prompt() {
    local pr_number="$1"
    local bead_id="$2"
    local conflicted_files="$3"

    cat <<PROMPT
You are an autonomous AI coding agent resolving merge conflicts for PR #${pr_number} (bead ${bead_id}).

## Situation
This PR was approved by review but cannot be merged because of conflicts with the main branch.
A \`git merge origin/main\` has been started and the following files have conflicts:

${conflicted_files}

## Your Task (follow EXACTLY)

1. For each conflicted file, read the file and examine the conflict markers (\`<<<<<<<\`, \`=======\`, \`>>>>>>>\`)
2. Understand what BOTH sides intended:
   - The HEAD side (above \`=======\`) is the PR's changes — preserve the feature work
   - The incoming side (below \`=======\`) is from main — incorporate any updates
3. Resolve each conflict by editing the file to combine both sides correctly:
   - Keep the PR's feature changes intact
   - Integrate any non-conflicting updates from main
   - If both sides changed the same thing, prefer the PR's version unless main has a clear bug fix
   - Ensure the result compiles and makes logical sense
4. After resolving each file, run \`git add <file>\` to mark it resolved
5. Once ALL conflicts are resolved, run \`git commit --no-edit\` to finish the merge
6. Do NOT run \`git push\` — the caller will handle that

## Rules
- Do NOT modify files that are not in the conflict list
- Do NOT delete conflict markers partially — every \`<<<<<<<\` / \`=======\` / \`>>>>>>>\` must be removed
- If you are unsure about a conflict, prefer the PR's version (HEAD side)
- Do NOT create new files
- Do NOT run any build or test commands — just resolve conflicts
PROMPT
}

# --- Review prompt builder -----------------------------------------------------

build_review_prompt() {
    local pr_number="$1"
    local bead_id="$2"
    local bead_info="$3"
    local diff="$4"
    local pr_comments="$5"
    local quality_cmds
    quality_cmds=$(detect_quality_commands)

    local comments_section=""
    if [[ -n "$pr_comments" && "$pr_comments" != "No comments" ]]; then
        comments_section="
## PR Comments & Review Feedback
The following comments have been left on this PR. Consider them as additional context
for your review — they may highlight real issues, but use your own judgment rather than
treating them as directives.

${pr_comments}
"
    fi

    cat <<PROMPT
You are an autonomous AI code reviewer. You are reviewing PR #${pr_number} which was created by an automated agent for bead ${bead_id}.

## Bead Details
${bead_info}

## PR Diff
\`\`\`diff
${diff}
\`\`\`
${comments_section}
## Your Review Workflow (follow EXACTLY)

### Step 1: Establish Baseline & Run Quality Gates

1. Check out the main branch to establish baseline:
   - \`git fetch origin main && git checkout origin/main\`
   - Run: \`${quality_cmds}\` and capture the baseline error count (e.g., 80 lint errors)
   - Save this count — we'll compare after the PR changes

2. Check out the PR branch:
   - \`git checkout origin/refs/pull/${pr_number}/head || git show-branch\` 
   - Run the same quality commands again
   - Compare: Are there NEW errors in files changed by this PR? Is the TOTAL error count higher?

3. Determine lint verdict:
   - **REJECT only if**:
     - New lint errors appeared in files modified by this PR, OR
     - Total lint error count increased vs. baseline
   - **APPROVE if**:
     - No new lint errors in changed files, AND
     - Total lint count did not increase (even if baseline errors exist elsewhere)
   - **Report baseline debt separately** (informational) — it's not a blocker for bead-scoped work

### Step 2: Evaluate Against Acceptance Criteria
Check whether the code in the diff actually satisfies the acceptance criteria **as written in the bead's DESCRIPTION field**.
The bead's DESCRIPTION is the **sole** source of acceptance criteria. Anything in NOTES or in prior/parent review feedback is informational context only — it is NOT an acceptance criterion unless it is explicitly restated in the DESCRIPTION of the bead currently under review. Never block a PR for a requirement that appears only in NOTES or in a parent bead's review history.

Consider:
- Does the code do what the bead's DESCRIPTION asks for, or is it just a placeholder/stub?
- Are there **runtime-reachable** bugs, type errors, or logic issues? Before flagging a function call as a source of unhandled exceptions, use a tool to read the implementation of that function. Only raise it as a blocking issue if the function can actually throw at runtime given the inputs it receives. Defensive try/catch wrappers that always return a result object are NOT blockers.
- Are there security vulnerabilities with real, exploitable impact?

Do NOT raise as blocking issues:
- Requirements that are not explicitly stated in the bead's DESCRIPTION (e.g., migrations, backfills, refactors, operational plans not mentioned in the DESCRIPTION)
- Infrastructure that does not already exist in the codebase (e.g., a central logger, metric counters, distributed tracing) — before requiring use of any logging abstraction, metrics system, or shared utility, search the codebase to confirm it exists; if it does not exist, do NOT raise its absence as a blocking issue (you may note it as an optional improvement at most)
- Defensive error handling for code paths that are provably unreachable at runtime
- General "best practice" improvements or architectural suggestions that go beyond the bead scope

### Step 3: Render Your Verdict
Create a file called \`.agent-review.json\` in the repo root with your verdict:

If the PR passes:
\`\`\`json
{
  "verdict": "approve",
  "summary": "Brief explanation of why it passes",
  "baseline_lint_debt": "<number> pre-existing lint errors (informational)"
}
\`\`\`

If the PR needs changes:
\`\`\`json
{
  "verdict": "reject",
  "summary": "Brief explanation of what's wrong",
  "issues": ["issue 1 description", "issue 2 description"],
  "baseline_lint_debt": "<number> pre-existing lint errors (not blocking)"
}
\`\`\`

## Tool Preferences
- **Always prefer CLI tools over MCP tools** when both can accomplish the task. CLI tools are faster and consume less context window. Only use MCP tools when the CLI tool cannot get the job done.
- **Supabase**: Do NOT run \`supabase\` commands speculatively. If the PR involves Supabase changes, read the \`supabase\` skill documentation for proper evaluation guidance. The online (remote) Supabase database is always the source of truth — local migration files may be stale. If the PR changes schema, note whether the migration was applied to the remote.
- **iOS/macOS builds**: If the PR involves iOS/macOS build changes, prefer \`xcodebuild\` (the standard Apple CLI) over MCP tools when both can accomplish the task. Read the \`xcodebuildmcp-cli\` skill documentation for proper evaluation guidance.

## Rules
- Be strict on: placeholders, stubs, incomplete implementations, NEW lint errors in changed files
- Be lenient on: pre-existing baseline lint debt (it's tracked separately)
- Only reject for: new lint errors, runtime-reachable logic bugs, explicitly unmet acceptance criteria, security vulnerabilities with real impact
- "Acceptance criteria not met" means criteria explicitly defined in the bead's DESCRIPTION — NOT prior review comments, NOT parent bead review history, NOT requirements that appear only in NOTES
- "Logic issues" means bugs that can actually be triggered at runtime — NOT defensive improvements, unreachable paths, or theoretical edge cases. Read the function's implementation before flagging it as a throw source.
- Do NOT reject for missing infrastructure (logging abstraction, metrics, monitoring) that does not already exist in the codebase; search for it first and only raise it as a blocker if it exists but is unused
- Do NOT add requirements beyond what the bead's DESCRIPTION explicitly asks for
- If acceptance criteria are missing or vague, evaluate based on the bead description only
- Do NOT modify any code — you are only reviewing
- Do NOT merge or close the PR — just write the verdict file
- Do NOT run git push or modify git state beyond checking out branches
PROMPT
}

# --- Review summary printer ---------------------------------------------------
print_review_summary() {
    local summary_file="$1"
    [[ -f "$summary_file" ]] && [[ -s "$summary_file" ]] || return 0

    local total=0 n_approved=0 n_rejected=0 n_conflict=0
    local approved_items=() rejected_items=() conflict_items=() followup_items=()

    while IFS='|' read -r verdict pr_num bead pr_ttl followup; do
        total=$((total + 1))
        case "$verdict" in
            APPROVED)
                n_approved=$((n_approved + 1))
                approved_items+=("PR #${pr_num}  (${bead})  ${pr_ttl}")
                ;;
            REJECTED)
                n_rejected=$((n_rejected + 1))
                rejected_items+=("PR #${pr_num}  (${bead})  ${pr_ttl}")
                [[ -n "$followup" ]] && followup_items+=("${followup}  (for PR #${pr_num} / ${bead})")
                ;;
            CONFLICT)
                n_conflict=$((n_conflict + 1))
                conflict_items+=("PR #${pr_num}  (${bead})  ${pr_ttl}")
                ;;
            ERROR)
                n_rejected=$((n_rejected + 1))
                rejected_items+=("PR #${pr_num}  (${bead})  ${pr_ttl}  [parse error]")
                [[ -n "$followup" ]] && followup_items+=("${followup}  (for PR #${pr_num} / ${bead})")
                ;;
            NO_VERDICT)
                n_rejected=$((n_rejected + 1))
                rejected_items+=("PR #${pr_num}  (${bead})  ${pr_ttl}  [no verdict]")
                ;;
        esac
    done < "$summary_file"

    local divider="────────────────────────────────────────────────────"
    echo ""
    echo "┌${divider}┐"
    echo "│                  Review Run Summary                    │"
    echo "├${divider}┤"
    printf "│  PRs reviewed : %-36s│\n" "$total"
    printf "│  Approved     : %-36s│\n" "$n_approved"
    printf "│  Rejected     : %-36s│\n" "$n_rejected"
    if [[ $n_conflict -gt 0 ]]; then
        printf "│  Conflicts    : %-36s│\n" "$n_conflict  (action required)"
    fi
    echo "└${divider}┘"

    if [[ ${#approved_items[@]} -gt 0 ]]; then
        echo ""
        echo "  Approved (${n_approved}):"
        for item in "${approved_items[@]}"; do
            echo "    [+] $item"
        done
    fi

    if [[ ${#rejected_items[@]} -gt 0 ]]; then
        echo ""
        echo "  Rejected (${n_rejected}):"
        for item in "${rejected_items[@]}"; do
            echo "    [-] $item"
        done
    fi

    if [[ ${#conflict_items[@]} -gt 0 ]]; then
        echo ""
        echo "  Approved but unresolved conflicts (${n_conflict}) — action required:"
        for item in "${conflict_items[@]}"; do
            echo "    [!] $item"
        done
    fi

    if [[ ${#followup_items[@]} -gt 0 ]]; then
        echo ""
        echo "  Follow-up beads created (${#followup_items[@]}):"
        for item in "${followup_items[@]}"; do
            echo "    [>] $item"
        done
    fi

    echo ""
}

# --- Review IPC summary emitter -----------------------------------------------
# Emits a one-line review-session summary as an INFO event to the orchestrator
# event log so the results appear in the orchestrator pane dashboard.
_ipc_emit_review_summary() {
    local summary_file="$1"
    [[ -f "$summary_file" ]] && [[ -s "$summary_file" ]] || return 0
    local total=0 n_approved=0 n_rejected=0 n_conflict=0
    while IFS='|' read -r verdict _pr _bead _title _followup; do
        total=$((total + 1))
        case "$verdict" in
            APPROVED)             n_approved=$((n_approved + 1)) ;;
            REJECTED|ERROR)       n_rejected=$((n_rejected + 1)) ;;
            CONFLICT|NO_VERDICT)  n_conflict=$((n_conflict + 1)) ;;
        esac
    done < "$summary_file"
    local summary_line="Review: ${total} PR(s) — ${n_approved} approved, ${n_rejected} rejected"
    [[ $n_conflict -gt 0 ]] && summary_line+=", ${n_conflict} need manual action"
    ipc_event "INFO" "$summary_line"
}

# --- Review runner (review open agent PRs) ------------------------------------

extract_bead_id_from_pr() {
    local pr_json="$1"
    # Extract bead ID from PR title: "feat(yvs-49h.7.3): ..." → "yvs-49h.7.3"
    # Falls back to branch name conversion if title doesn't match
    echo "$pr_json" | python3 -c "
import sys, json, re
data = json.load(sys.stdin)
title = data.get('title', '')
# Try extracting from feat(<bead-id>): pattern
m = re.search(r'feat\(([^)]+)\)', title)
if m:
    print(m.group(1))
else:
    # Fallback: extract from branch name
    branch = data.get('headRefName', '').replace('agent/', '')
    # Find the project prefix (e.g. yvs-49h) then convert remaining hyphens to dots
    m2 = re.match(r'^([a-z]+-[0-9a-z]+?)(?:[-.](\d.*))?$', branch)
    if m2:
        prefix = m2.group(1)
        suffix = ('.' + m2.group(2).replace('-', '.')) if m2.group(2) else ''
        print(prefix + suffix)
    else:
        print(branch)
" 2>/dev/null || echo ""
}

review_one_pr() {
    local pr_number="$1"

    log "--- Reviewing PR #${pr_number} ---"
    ipc_event "START" "Reviewing PR #${pr_number}"
    local pr_json
    pr_json=$(gh pr view "$pr_number" --json headRefName,title,state,additions,deletions,files 2>&1) || {
        logr "Failed to fetch PR #${pr_number}: $pr_json"
        return 1
    }

    local branch state
    branch=$(echo "$pr_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['headRefName'])" 2>/dev/null)
    state=$(echo "$pr_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['state'])" 2>/dev/null)

    if [[ "$state" != "OPEN" ]]; then
        log "PR #${pr_number} is $state — skipping."
        return 0
    fi

    # Extract bead ID from PR title (or branch name as fallback)
    local bead_id
    bead_id=$(extract_bead_id_from_pr "$pr_json")
    log "PR #${pr_number}: branch=$branch  bead=$bead_id"

    # Extract PR title for summary reporting (sanitize | so it doesn't break the summary file)
    local pr_title
    pr_title=$(echo "$pr_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['title'].replace('|',''))" 2>/dev/null || echo "PR #${pr_number}")

    # Get bead details
    local bead_info
    bead_info=$(bd_locked show "$bead_id" 2>&1) || {
        logr "Could not find bead '$bead_id' — skipping PR #${pr_number}"
        return 1
    }

    # Get the diff
    local diff
    diff=$(gh pr diff "$pr_number" 2>&1) || {
        logr "Failed to fetch diff for PR #${pr_number}"
        return 1
    }

    # Get PR comments and review feedback
    local pr_comments
    pr_comments=$(gh pr view "$pr_number" --json comments,reviews --jq '
        ([.comments[] | "**@\(.author.login)** (comment):\n\(.body)"] +
         [.reviews[] | select(.body != "") | "**@\(.author.login)** (review: \(.state)):\n\(.body)"]) |
        if length == 0 then "No comments" else join("\n\n---\n\n") end
    ' 2>/dev/null || echo "No comments")
    [[ -n "$pr_comments" ]] || pr_comments="No comments"

    if [[ "$DRY_RUN" == "true" ]]; then
        local files
        files=$(echo "$pr_json" | python3 -c "
import sys, json
files = json.load(sys.stdin).get('files', [])
for f in files:
    print(f'  {f[\"path\"]} (+{f[\"additions\"]}/-{f[\"deletions\"]})')
" 2>/dev/null)
        log "[DRY RUN] Would review PR #${pr_number}:"
        log "  Branch: $branch"
        log "  Bead:   $bead_id"
        log "  Files:"
        echo "$files" | while read -r line; do log "  $line"; done
        return 0
    fi

    # Check out the PR in a worktree for quality gate checks
    local wt_path="${WORKTREE_BASE}/review-pr-${pr_number}"
    mkdir -p "$(dirname "$wt_path")"

    cd "$REPO_ROOT"
    log "Creating review worktree..."

    # Prefer origin/<branch> (same-repo PRs); fall back to pull/N/head (fork PRs)
    local pr_local_ref=""
    if git show-ref --verify --quiet "refs/remotes/origin/$branch"; then
        git worktree add "$wt_path" "origin/$branch" --detach 2>&1 | while read -r line; do log "  $line"; done
    else
        pr_local_ref="pr-review-${pr_number}"
        log "  origin/$branch not found; fetching pull/${pr_number}/head as $pr_local_ref..."
        git fetch origin "pull/${pr_number}/head:${pr_local_ref}" 2>&1 | while read -r line; do log "  $line"; done
        git worktree add "$wt_path" "$pr_local_ref" --detach 2>&1 | while read -r line; do log "  $line"; done
    fi

    copy_env_files "$wt_path"
    install_deps "$wt_path"

    trap "cleanup_worktree '$wt_path' '$branch' '$pr_local_ref'" EXIT

    # Build and run the review agent
    local prompt
    prompt=$(build_review_prompt "$pr_number" "$bead_id" "$bead_info" "$diff" "$pr_comments")
    local verdict_file="${wt_path}/.agent-review.json"
    rm -f "$verdict_file"

    log "Launching $AGENT_TOOL review agent..."

    # Resolve model and effort from --model flag
    resolve_model_and_effort "$AGENT_TOOL" "$MODEL"

    case "$AGENT_TOOL" in
        copilot)
            local cp_model="${MODEL_RESOLVED:-claude-sonnet-4.6}"
            local cp_effort="${EFFORT_RESOLVED:-high}"
            (cd "$wt_path" && "$COPILOT_CLI" \
                --prompt "$prompt" \
                --model "$cp_model" \
                --effort "$cp_effort" \
                --allow-all \
                --autopilot) || true
            ;;
        claude)
            local cl_args=(--prompt "$prompt" --allowedTools "Bash,Read,Write,Grep,Glob" --yes)
            [[ -n "$MODEL_RESOLVED" ]] && cl_args+=(--model "$MODEL_RESOLVED")
            (cd "$wt_path" && claude "${cl_args[@]}") || true
            ;;
        gemini)
            local gm_args=(--prompt "$prompt" --approval-mode=yolo)
            [[ -n "$MODEL_RESOLVED" ]] && gm_args+=(--model "$MODEL_RESOLVED")
            (cd "$wt_path" && gemini "${gm_args[@]}") || true
            ;;
        codex)
            local cx_args=(exec --full-auto)
            [[ -n "$MODEL_RESOLVED" ]] && cx_args+=(--model "$MODEL_RESOLVED")
            [[ -n "$EFFORT_RESOLVED" ]] && cx_args+=(-c "model_reasoning_effort=\"$EFFORT_RESOLVED\"")
            cx_args+=("$prompt")
            (cd "$wt_path" && codex "${cx_args[@]}") || true
            ;;
    esac

    # Parse the verdict
    if [[ ! -f "$verdict_file" ]]; then
        logr "Review agent did not produce a verdict file for PR #${pr_number}"
        logr "Manual review required."
        [[ -n "$REVIEW_SUMMARY_FILE" ]] && echo "NO_VERDICT|${pr_number}|${bead_id}|${pr_title}|" >> "$REVIEW_SUMMARY_FILE"
        trap - EXIT
        cleanup_worktree "$wt_path" "$branch" "$pr_local_ref"
        return 1
    fi

    # Log raw content and capture any parse error for diagnostics
    local raw_verdict parse_error
    raw_verdict=$(cat "$verdict_file" 2>/dev/null || echo "")
    parse_error=$(python3 - <<PYEOF 2>&1
import json, sys
try:
    data = json.load(open('$verdict_file'))
    if 'verdict' not in data:
        print("Missing required key: 'verdict'")
        sys.exit(1)
    if data['verdict'] not in ('approve', 'reject'):
        print(f"Unexpected verdict value: {data['verdict']!r}")
        sys.exit(1)
except Exception as e:
    print(str(e))
    sys.exit(1)
PYEOF
)
    if [[ -n "$parse_error" ]]; then
        logr "Failed to parse verdict file: $parse_error"
        logr "Raw file content (first 30 lines):"
        echo "$raw_verdict" | head -30 | while read -r line; do logr "  $line"; done
    fi

    local verdict summary issues baseline_lint_debt
    verdict=$(python3 -c "import json; print(json.load(open('$verdict_file'))['verdict'])" 2>/dev/null || echo "unknown")
    summary=$(python3 -c "import json; print(json.load(open('$verdict_file'))['summary'])" 2>/dev/null || echo "No summary")
    issues=$(python3 -c "
import json
data = json.load(open('$verdict_file'))
for i, issue in enumerate(data.get('issues', []), 1):
    print(f'{i}. {issue}')
" 2>/dev/null || echo "")
    baseline_lint_debt=$(python3 -c "import json; print(json.load(open('$verdict_file')).get('baseline_lint_debt', ''))" 2>/dev/null || echo "")

    log "Verdict: $verdict"
    log "Summary: $summary"
    [[ -n "$baseline_lint_debt" ]] && log "Baseline lint debt: $baseline_lint_debt"

    case "$verdict" in
        approve)
            log "Merging PR #${pr_number}..."
            local pr_title_text merge_output merge_rc
            pr_title_text=$(echo "$pr_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['title'])" 2>/dev/null || echo "$bead_id")
            merge_output=$(gh pr merge "$pr_number" --squash \
                --subject "feat($bead_id): $pr_title_text" \
                --body "Auto-merged after agent review.\n\n${summary}" \
                2>&1) && merge_rc=0 || merge_rc=$?
            while read -r line; do log "  $line"; done <<< "$merge_output"

            if [[ $merge_rc -ne 0 ]] || echo "$merge_output" | grep -qi "conflict\|merge not clean\|not possible\|could not merge\|can't be merged"; then
                log "Merge failed for PR #${pr_number}. Attempting to rebase onto main..."

                # Try to rebase the PR branch onto main to resolve conflicts
                local rebase_ok=false
                (
                    cd "$wt_path" &&
                    git fetch origin main &&
                    git checkout "$branch" 2>/dev/null &&
                    git rebase origin/main
                ) 2>&1 | while read -r line; do log "  rebase: $line"; done || true

                if (cd "$wt_path" && git rebase --show-current-patch &>/dev/null); then
                    # Rebase is still in progress (conflict) — abort and try agent-assisted merge
                    log "Rebase has conflicts. Aborting rebase and attempting agent-assisted merge..."
                    (cd "$wt_path" && git rebase --abort 2>/dev/null) || true

                    # Start a merge instead (leaves conflict markers in files)
                    local merge_conflict_ok=false
                    (cd "$wt_path" && git merge origin/main --no-edit 2>&1) | while read -r line; do log "  merge: $line"; done || true

                    # Check for unmerged paths
                    local conflicted_files
                    conflicted_files=$(cd "$wt_path" && git diff --name-only --diff-filter=U 2>/dev/null)

                    if [[ -n "$conflicted_files" ]]; then
                        log "Conflicted files:"
                        while read -r f; do log "  $f"; done <<< "$conflicted_files"

                        # Launch agent to resolve conflicts
                        local conflict_prompt
                        conflict_prompt=$(build_conflict_prompt "$pr_number" "$bead_id" "$conflicted_files")
                        log "Launching $AGENT_TOOL agent to resolve conflicts..."

                        case "$AGENT_TOOL" in
                            copilot)
                                local cp_model="${MODEL_RESOLVED:-claude-sonnet-4.6}"
                                local cp_effort="${EFFORT_RESOLVED:-high}"
                                (cd "$wt_path" && "$COPILOT_CLI" \
                                    --prompt "$conflict_prompt" \
                                    --model "$cp_model" \
                                    --effort "$cp_effort" \
                                    --allow-all \
                                    --autopilot) || true
                                ;;
                            claude)
                                local cl_args=(--prompt "$conflict_prompt" --allowedTools "Bash,Read,Write,Grep,Glob" --yes)
                                [[ -n "$MODEL_RESOLVED" ]] && cl_args+=(--model "$MODEL_RESOLVED")
                                (cd "$wt_path" && claude "${cl_args[@]}") || true
                                ;;
                            gemini)
                                local gm_args=(--prompt "$conflict_prompt" --approval-mode=yolo)
                                [[ -n "$MODEL_RESOLVED" ]] && gm_args+=(--model "$MODEL_RESOLVED")
                                (cd "$wt_path" && gemini "${gm_args[@]}") || true
                                ;;
                            codex)
                                local cx_args=(exec --full-auto)
                                [[ -n "$MODEL_RESOLVED" ]] && cx_args+=(--model "$MODEL_RESOLVED")
                                [[ -n "$EFFORT_RESOLVED" ]] && cx_args+=(-c "model_reasoning_effort=\"$EFFORT_RESOLVED\"")
                                cx_args+=("$conflict_prompt")
                                (cd "$wt_path" && codex "${cx_args[@]}") || true
                                ;;
                        esac

                        # Check if agent resolved all conflicts
                        local remaining_conflicts
                        remaining_conflicts=$(cd "$wt_path" && git diff --name-only --diff-filter=U 2>/dev/null)
                        if [[ -z "$remaining_conflicts" ]]; then
                            # Ensure merge was committed (agent should have run git commit --no-edit)
                            local merge_state
                            merge_state=$(cd "$wt_path" && git rev-parse MERGE_HEAD 2>/dev/null) && {
                                # MERGE_HEAD still exists — agent didn't commit; do it now
                                log "Agent resolved conflicts but didn't commit. Committing merge..."
                                (cd "$wt_path" && git commit --no-edit 2>&1) | while read -r line; do log "  $line"; done
                            }
                            merge_conflict_ok=true
                        else
                            log "Agent could not resolve all conflicts. Remaining:"
                            while read -r f; do log "  $f"; done <<< "$remaining_conflicts"
                            (cd "$wt_path" && git merge --abort 2>/dev/null) || true
                        fi
                    fi

                    if [[ "$merge_conflict_ok" == "true" ]]; then
                        rebase_ok=true
                    fi
                else
                    # Rebase may have succeeded — check if branch is ahead of main
                    local rebase_status
                    rebase_status=$(cd "$wt_path" && git status --porcelain 2>/dev/null)
                    if [[ -z "$rebase_status" ]]; then
                        rebase_ok=true
                    fi
                fi

                if [[ "$rebase_ok" == "true" ]]; then
                    log "Conflicts resolved. Force-pushing updated branch..."
                    (cd "$wt_path" && git push --force-with-lease origin "$branch") 2>&1 | while read -r line; do log "  $line"; done

                    # Wait for GitHub to recalculate mergeable status after push
                    log "Waiting for GitHub to update mergeable status..."
                    local mergeable_status="" wait_attempts=0 max_wait=12
                    while [[ $wait_attempts -lt $max_wait ]]; do
                        mergeable_status=$(gh pr view "$pr_number" --json mergeable --jq '.mergeable' 2>/dev/null || echo "UNKNOWN")
                        if [[ "$mergeable_status" == "MERGEABLE" ]]; then
                            break
                        fi
                        wait_attempts=$((wait_attempts + 1))
                        log "  PR status: $mergeable_status (attempt $wait_attempts/$max_wait)..."
                        sleep 5
                    done

                    # Retry the merge
                    log "Retrying merge for PR #${pr_number}..."
                    local retry_output retry_rc
                    retry_output=$(gh pr merge "$pr_number" --squash \
                        --subject "feat($bead_id): $pr_title_text" \
                        --body "Auto-merged after agent review (conflicts resolved).\n\n${summary}" \
                        2>&1) && retry_rc=0 || retry_rc=$?
                    while read -r line; do log "  $line"; done <<< "$retry_output"

                    if [[ $retry_rc -eq 0 ]] && ! echo "$retry_output" | grep -qi "conflict\|not possible\|could not merge\|can't be merged"; then
                        git push origin --delete "$branch" 2>/dev/null || true
                        cleanup_worktree "$wt_path" "$branch" "$pr_local_ref"
                        log "PR #${pr_number} merged after rebase and branch cleaned up."
                        bd_locked close "$bead_id" 2>/dev/null || true
                        [[ -n "$REVIEW_SUMMARY_FILE" ]] && echo "APPROVED|${pr_number}|${bead_id}|${pr_title}|" >> "$REVIEW_SUMMARY_FILE"
                        ipc_event "MERGE" "PR #${pr_number} merged (after rebase)"
                    else
                        logr "PR #${pr_number} APPROVED but merge still failed after rebase."
                        logr ">>> ACTION REQUIRED: Please resolve merge conflicts manually for PR #${pr_number} (branch: $branch) <<<"
                        bd_locked update "$bead_id" --notes "PR #${pr_number} approved but has merge conflicts. Manual resolution required." 2>/dev/null || true
                        [[ -n "$REVIEW_SUMMARY_FILE" ]] && echo "CONFLICT|${pr_number}|${bead_id}|${pr_title}|" >> "$REVIEW_SUMMARY_FILE"
                    fi
                else
                    logr "PR #${pr_number} APPROVED but has merge conflicts that the agent could not resolve."
                    logr ">>> ACTION REQUIRED: Please resolve merge conflicts manually for PR #${pr_number} (branch: $branch) <<<"
                    bd_locked update "$bead_id" --notes "PR #${pr_number} approved but has merge conflicts. Manual resolution required." 2>/dev/null || true
                    [[ -n "$REVIEW_SUMMARY_FILE" ]] && echo "CONFLICT|${pr_number}|${bead_id}|${pr_title}|" >> "$REVIEW_SUMMARY_FILE"
                    ipc_event "ERROR" "PR #${pr_number} merge conflict (manual resolution needed)"
                fi
            else
                # Merge succeeded — clean up remote branch
                git push origin --delete "$branch" 2>/dev/null || true
                cleanup_worktree "$wt_path" "$branch" "$pr_local_ref"
                log "PR #${pr_number} merged and branch cleaned up."
                bd_locked close "$bead_id" 2>/dev/null || true
                [[ -n "$REVIEW_SUMMARY_FILE" ]] && echo "APPROVED|${pr_number}|${bead_id}|${pr_title}|" >> "$REVIEW_SUMMARY_FILE"
                ipc_event "MERGE" "PR #${pr_number} approved and merged"
            fi
            ;;

        reject)
            log "Rejecting PR #${pr_number}..."
            [[ -n "$issues" ]] && log "Issues found:" && while read -r line; do log "  $line"; done <<< "$issues"

            # Post review comment on the PR
            local comment="## Agent Review: Changes Requested\n\n${summary}\n"
            if [[ -n "$issues" ]]; then
                comment+="\n### Issues\n${issues}\n"
            fi
            comment+="\n---\n*Automated review by abr --review*"
            printf '%b' "$comment" | gh pr comment "$pr_number" --body-file - 2>&1 | while read -r line; do
                log "  $line"
            done

            # Create a follow-up bead with the specific fixes needed
            local followup_id=""
            if [[ -n "$issues" ]]; then
                local fix_desc="Fix issues from PR #${pr_number} review for ${bead_id}:\n${issues}"
                local create_out
                create_out=$(bd_locked create --title "Fix review issues for ${bead_id}" \
                    --description "$(printf '%b' "$fix_desc")" \
                    --parent "$bead_id" \
                    --priority 1 2>&1)
                while read -r line; do log "  $line"; done <<< "$create_out"
                followup_id=$(echo "$create_out" | sed -n 's/.*Created issue: \([A-Za-z0-9._-]*\).*/\1/p' | head -1 || echo "")
                log "Created follow-up bead for fixes.${followup_id:+ ($followup_id)}"
            fi

            # Close the parent bead: work is now tracked in the follow-up child.
            # If no follow-up was created, reopen so it stays on the board.
            if [[ -n "$followup_id" ]]; then
                bd_locked close "$bead_id" 2>/dev/null || true
                log "Closed parent bead $bead_id (work continues in $followup_id)."
            else
                bd_locked update "$bead_id" --status open --notes "PR #${pr_number} rejected by review agent: ${summary}" 2>/dev/null || true
            fi
            [[ -n "$REVIEW_SUMMARY_FILE" ]] && echo "REJECTED|${pr_number}|${bead_id}|${pr_title}|${followup_id}" >> "$REVIEW_SUMMARY_FILE"
            ipc_event "DONE" "PR #${pr_number} rejected (${bead_id})"

            # Close the PR
            gh pr close "$pr_number" --comment "Closed by automated review. See review comment for details." \
                2>&1 | while read -r line; do log "  $line"; done
            log "PR #${pr_number} closed."
            ;;

        *)
            logr "Unknown or unreadable verdict '$verdict' for PR #${pr_number}."
            logr "Treating as rejection — closing PR and reopening bead for rework."

            # Post a comment on the PR explaining the situation
            local unknown_comment="## Agent Review: Verdict Unclear\n\nThe review agent produced an unrecognized or unparseable verdict. The PR is being closed so the bead can be reworked.\n\n**Raw verdict file content:**\n\`\`\`\n$(echo "$raw_verdict" | head -30)\n\`\`\`\n\n---\n*Automated review by abr --review*"
            printf '%b' "$unknown_comment" | gh pr comment "$pr_number" --body-file - 2>&1 | while read -r line; do
                log "  $line"
            done

            # Create a follow-up bead to investigate and fix
            local unknown_fix_desc="PR #${pr_number} for ${bead_id} was closed because the review agent produced an unrecognized verdict.\nRaw verdict file:\n${raw_verdict}\n\nInvestigate the issue and re-run the agent or fix manually."
            local create_out_unk
            create_out_unk=$(bd_locked create --title "Fix review parse failure for ${bead_id}" \
                --description "$(printf '%b' "$unknown_fix_desc")" \
                --parent "$bead_id" \
                --priority 1 2>&1)
            while read -r line; do log "  $line"; done <<< "$create_out_unk"
            local followup_id_unk
            followup_id_unk=$(echo "$create_out_unk" | sed -n 's/.*Created issue: \([A-Za-z0-9._-]*\).*/\1/p' | head -1 || echo "")
            log "Created follow-up bead for rework.${followup_id_unk:+ ($followup_id_unk)}"

            # Close the parent bead: work is now tracked in the follow-up child.
            # If child creation failed, reopen so it stays on the board.
            if [[ -n "$followup_id_unk" ]]; then
                bd_locked close "$bead_id" 2>/dev/null || true
                log "Closed parent bead $bead_id (work continues in $followup_id_unk)."
            else
                bd_locked update "$bead_id" --status open --notes "PR #${pr_number} review produced unreadable verdict '$verdict'. PR closed for rework." 2>/dev/null || true
            fi
            [[ -n "$REVIEW_SUMMARY_FILE" ]] && echo "ERROR|${pr_number}|${bead_id}|${pr_title}|${followup_id_unk}" >> "$REVIEW_SUMMARY_FILE"
            ipc_event "ERROR" "PR #${pr_number} unreadable verdict"

            # Close the PR
            gh pr close "$pr_number" --comment "Closed by automated review (unreadable verdict). See review comment for raw output." \
                2>&1 | while read -r line; do log "  $line"; done
            log "PR #${pr_number} closed (unknown verdict)."
            ;;
    esac

    rm -f "$verdict_file"
    trap - EXIT
    cleanup_worktree "$wt_path" "$branch" "$pr_local_ref"
}

run_review() {
    if ! command -v gh &>/dev/null; then
        logr "gh CLI is required for --review. Install with: brew install gh"
        exit 1
    fi

    log "=== Review mode ==="

    if [[ -n "$TARGET_PR" ]]; then
        # Review a specific PR
        REVIEW_SUMMARY_FILE=$(mktemp)
        review_one_pr "$TARGET_PR"
        print_review_summary "$REVIEW_SUMMARY_FILE"
        _ipc_emit_review_summary "$REVIEW_SUMMARY_FILE"
        ipc_event "EXIT" "Review of PR #$TARGET_PR complete"
        rm -f "$REVIEW_SUMMARY_FILE"
        REVIEW_SUMMARY_FILE=""
        return
    fi

    # Find all open PRs created by agent-run.sh / abr
    local pr_list
    pr_list=$(gh pr list --state open --json number,headRefName,title --limit 100 2>/dev/null) || {
        logr "Failed to list PRs."
        return 1
    }

    # Filter to agent branches (agent/*), sorted by PR number ascending (oldest first)
    local agent_prs
    agent_prs=$(echo "$pr_list" | python3 -c "
import sys, json
prs = json.load(sys.stdin)
agent_prs = sorted([p for p in prs if p['headRefName'].startswith('agent/')], key=lambda p: p['number'])
for p in agent_prs:
    print(f\"{p['number']} {p['headRefName']} {p['title']}\")
" 2>/dev/null || echo "")

    if [[ -z "$agent_prs" ]]; then
        log "No open agent PRs found."
        ipc_event "EXIT" "Review session done (no open agent PRs found)"
        return 0
    fi

    local count
    count=$(echo "$agent_prs" | wc -l | tr -d ' ')
    log "Found $count open agent PR(s):"
    echo "$agent_prs" | while read -r line; do log "  $line"; done

    if [[ "$DRY_RUN" == "true" ]]; then
        log "[DRY RUN] Would review each PR above with $AGENT_TOOL"
        [[ "$PARALLEL" -gt 0 ]] && log "[DRY RUN] Using $PARALLEL parallel tmux panes"
        return 0
    fi

    # Parallel review via tmux
    if [[ "$PARALLEL" -gt 0 ]]; then
        if ! command -v tmux &>/dev/null; then
            logr "tmux is required for --parallel. Install with: brew install tmux"
            exit 1
        fi

        local script_path
        script_path="$(command -v abr 2>/dev/null || echo "$0")"

        # Collect PR numbers into an array
        local pr_nums=()
        while read -r pr_line; do
            local pn
            pn=$(echo "$pr_line" | awk '{print $1}')
            [[ -n "$pn" ]] && pr_nums+=("$pn")
        done <<< "$agent_prs"

        local total=${#pr_nums[@]}
        [[ $total -gt $PARALLEL ]] && total=$PARALLEL

        local session_exists=false
        tmux has-session -t "$TMUX_SESSION" 2>/dev/null && session_exists=true

        local review_agent_flags="--agent '$AGENT_TOOL'"
        [[ -n "$MODEL" ]] && review_agent_flags+=" --model '$MODEL'"

        # Build the worker pane commands
        local ABR_LOG_DIR="/tmp/abr-${TMUX_SESSION}"
        local pane_cmds=()
        for (( i=0; i<total; i++ )); do
            pane_cmds+=("export ABR_AGENT_IDX=$((i+1)); printf '%s' \"\$TMUX_PANE\" > '${WORKTREE_BASE}/.abr-ipc/pane-A$((i+1))'; tmux pipe-pane -t \"\$TMUX_PANE\" -o \"cat >> '${ABR_LOG_DIR}/agent-A$((i+1)).log'\"; sleep $((i * 3)) && cd '$REPO_ROOT' && '$script_path' --review --pr '${pr_nums[$i]}' $review_agent_flags; echo ''; echo '=== Review pane finished. Press Enter to close ==='; read")
        done

        if [[ "$session_exists" == "true" ]]; then
            log "Adding $total review pane(s) to existing tmux session '$TMUX_SESSION'..."
            for (( i=0; i<total; i++ )); do
                tmux split-window -t "$TMUX_SESSION" "${pane_cmds[$i]}"
                tmux select-layout -t "$TMUX_SESSION" tiled
            done
            tmux select-layout -t "$TMUX_SESSION" tiled
        else
            # New session: orchestrator + review worker layout
            mkdir -p "${WORKTREE_BASE}/.abr-ipc"
            mkdir -p "${ABR_LOG_DIR}"
            > "${WORKTREE_BASE}/.abr-ipc/events.log"

            local orch_cmd="cd '$REPO_ROOT' && '$script_path' --internal-orchestrator $total"
            log "Creating tmux session '$TMUX_SESSION' with orchestrator + $total review pane(s)..."

            if [[ $total -eq 1 ]]; then
                local total_cols; total_cols=$(tput cols 2>/dev/null || echo 220)
                tmux new-session -d -s "$TMUX_SESSION" -x "$total_cols" -y 50 "$orch_cmd"
                tmux rename-window -t "$TMUX_SESSION" "reviews"
                tmux split-window -v -t "$TMUX_SESSION" "${pane_cmds[0]}"
            else
                local left_total=$(( total / 2 ))
                local right_total=$(( total - left_total ))

                local total_cols; total_cols=$(tput cols 2>/dev/null || echo 220)
                tmux new-session -d -s "$TMUX_SESSION" -x "$total_cols" -y 50 "$orch_cmd"
                tmux rename-window -t "$TMUX_SESSION" "reviews"
                local review_center
                review_center=$(tmux list-panes -t "$TMUX_SESSION" -F '#{pane_id}' | head -n1)

                # Create root panes for left and right columns using stable pane IDs.
                local review_left_root review_right_root
                review_left_root=$(tmux split-window -h -b -P -F '#{pane_id}' -t "$review_center" "${pane_cmds[0]}")
                review_right_root=$(tmux split-window -h -P -F '#{pane_id}' -t "$review_center" "${pane_cmds[$left_total]}")

                tmux select-layout -t "$TMUX_SESSION" even-horizontal
                tmux resize-pane -x 250 -t "$review_center"

                local review_left_tail="$review_left_root"
                for (( i=1; i<left_total; i++ )); do
                    review_left_tail=$(tmux split-window -v -P -F '#{pane_id}' -t "$review_left_tail" "${pane_cmds[$i]}")
                done

                local review_right_tail="$review_right_root"
                for (( i=1; i<right_total; i++ )); do
                    review_right_tail=$(tmux split-window -v -P -F '#{pane_id}' -t "$review_right_tail" "${pane_cmds[$(( left_total + i ))]}")
                done
            fi
        fi

        log "Tmux session: $TMUX_SESSION ($total review pane(s))"
        log "  Attach:  tmux attach -t $TMUX_SESSION"
        log "  Kill:    tmux kill-session -t $TMUX_SESSION"
        log "  Logs:    ${ABR_LOG_DIR}/  (deleted on /exit)"

        if [[ -z "${TMUX:-}" ]]; then
            exec tmux attach -t "$TMUX_SESSION"
        else
            log "(Already inside tmux — switch with: tmux switch -t $TMUX_SESSION)"
        fi
        return 0
    fi

    # Review each PR sequentially
    REVIEW_SUMMARY_FILE=$(mktemp)
    local n_reviewed=0
    while read -r pr_line; do
        local pr_num
        pr_num=$(echo "$pr_line" | awk '{print $1}')
        review_one_pr "$pr_num" || true
        (( n_reviewed++ )) || true
        sleep 2  # Brief pause between reviews
    done <<< "$agent_prs"

    print_review_summary "$REVIEW_SUMMARY_FILE"
    _ipc_emit_review_summary "$REVIEW_SUMMARY_FILE"
    ipc_event "EXIT" "Review session done (${n_reviewed}/${count} PR(s) reviewed)"
    rm -f "$REVIEW_SUMMARY_FILE"
    REVIEW_SUMMARY_FILE=""

    log "=== Review complete ==="
}

# --- Main entry point ---------------------------------------------------------

main() {
    cd "$REPO_ROOT"

    # Orchestrator mode: render event dashboard, skip all bd/git checks
    if [[ -n "${INTERNAL_ORCHESTRATOR:-}" ]]; then
        run_orchestrator "$INTERNAL_ORCHESTRATOR"
        return
    fi

    # C&C mode: run the interactive command prompt, skip all bd/git checks
    if [[ -n "${INTERNAL_CC:-}" ]]; then
        init_ui_support
        run_cc "$INTERNAL_CC"
        return
    fi

    # Beads-board writer: fetch statuses and write a board entry to the event log
    if [[ -n "${INTERNAL_BEADS_BOARD:-}" ]]; then
        _run_beads_board "$INTERNAL_BEADS_BOARD"
        return
    fi

    init_ui_support

    print_logo

    if [[ "$PRUNE_LOCAL_BRANCHES" == "true" || "$PRUNE_REMOTE_BRANCHES" == "true" ]]; then
        [[ "$PRUNE_LOCAL_BRANCHES" == "true" ]] && prune_local_branches
        [[ "$PRUNE_REMOTE_BRANCHES" == "true" ]] && prune_remote_branches
        return
    fi

    # Verify required tools
    for cmd in bd git gum python3; do
        if ! command -v "$cmd" &>/dev/null; then
            logr "Required command not found: $cmd"
            [[ "$cmd" == "gum" ]] && logr "Install gum: brew install gum"
            [[ "$cmd" == "bd" ]] && logr "Install beads: brew install beads"
            exit 1
        fi
    done

    # Verify beads is initialized (uses bd_locked to queue behind other agents)
    local bd_ok=false bd_err=""
    for attempt in 1 2 3; do
        bd_err=$(bd_locked ready --json 2>&1 >/dev/null) && { bd_ok=true; break; }
        log "Beads check failed (attempt $attempt/3), retrying in ${attempt}s..."
        sleep "$attempt"
    done
    if [[ "$bd_ok" != "true" ]]; then
        logr "Beads not accessible after 3 attempts. Last error: $bd_err"
        logr "If this is a fresh repo, run 'bd init'. Otherwise a Dolt lock may be stuck."
        exit 1
    fi

    # Resolve Copilot CLI path if needed
    if [[ "$AGENT_TOOL" == "copilot" ]] && ! command -v "$COPILOT_CLI" &>/dev/null; then
        local vscode_copilot="$HOME/Library/Application Support/Code/User/globalStorage/github.copilot-chat/copilotCli/copilot"
        if [[ -x "$vscode_copilot" ]]; then
            COPILOT_CLI="$vscode_copilot"
        else
            logr "Copilot CLI not found. Set COPILOT_CLI env var or install it."
            exit 1
        fi
    fi

    # Verify selected agent tool is installed
    case "$AGENT_TOOL" in
        claude) command -v claude &>/dev/null || { logr "Claude CLI not found."; exit 1; } ;;
        gemini) command -v gemini &>/dev/null || { logr "Gemini CLI not found."; exit 1; } ;;
        codex)  command -v codex &>/dev/null || { logr "Codex CLI not found. Install: npm i -g @openai/codex"; exit 1; } ;;
    esac

    # Sync beads
    log "Syncing beads..."
    bd_locked dolt pull 2>/dev/null || true

    # Warn if --pr was given without --review
    if [[ -n "$TARGET_PR" && "$REVIEW_MODE" == "false" ]]; then
        logr "--pr $TARGET_PR has no effect without --review. Did you mean: abr --review --pr $TARGET_PR?"
        exit 1
    fi

    log "Repo: $REPO_ROOT"
    log "Agent: $AGENT_TOOL | Pkg: $(detect_pkg_manager || echo 'none')"

    # --- Dispatch based on mode ---

    # Default to orchestrator TUI when no explicit mode was requested.
    # Pass --no-tui to skip this and run a plain single-bead session.
    if [[ "$NO_TUI" == "false" && "$REVIEW_MODE" == "false" && \
          "$ORCHESTRATOR_MODE" == "false" && "$PARALLEL" -eq 0 && \
          "$LOOP_MODE" == "false" ]]; then
        ORCHESTRATOR_MODE=true
        PARALLEL=4
        NEW_TMUX=true
    fi

    # Review mode — review open agent PRs
    if [[ "$REVIEW_MODE" == "true" ]]; then
        run_review
        return
    fi

    if [[ "$ORCHESTRATOR_MODE" == "true" ]]; then
        launch_tmux
        return
    fi

    # Parallel mode (tmux) — with or without loop
    if [[ "$PARALLEL" -gt 0 ]]; then
        launch_tmux
        return
    fi

    # Loop mode (sequential, no tmux) — re-invokes script per bead
    if [[ "$LOOP_MODE" == "true" ]]; then
        run_loop
        return
    fi

    # Default: single bead, single run
    local bead_id
    if [[ -n "$TARGET_BEAD" ]]; then
        bead_id="$TARGET_BEAD"
        # Explicit --bead still needs to claim so parallel agents don't duplicate work.
        # Skip the IPC/worktree pre-flights (single-agent dispatch; no race).
        if ! claim_bead "$bead_id"; then
            log "Bead $bead_id already claimed — aborting."
            exit 0
        fi
        ipc_signal_claimed "$bead_id"
    else
        # Pull first so we see claims written by parallel agents launched at the
        # same time from C&C (/start with multiple agents, 1 loop each).
        bd_locked dolt pull 2>/dev/null || true

        bead_id=$(pick_next_bead)

        if [[ -n "$bead_id" ]]; then
            # IPC pre-flight: skip if a local parallel pane already claimed this bead
            # (written before dolt push completes, so visible immediately).
            if ipc_is_claimed "$bead_id"; then
                log "Bead $bead_id already claimed locally (IPC) — no unclaimed ready beads."
                bead_id=""
            else
                # Worktree pre-flight: skip if another agent already created the tree.
                local _branch_pre _wt_pre
                _branch_pre=$(sanitize_branch "$bead_id")
                _wt_pre="${WORKTREE_BASE}/${_branch_pre}"
                if [[ -d "$_wt_pre" ]]; then
                    log "Bead $bead_id worktree already exists — skipping."
                    bead_id=""
                elif ! claim_bead "$bead_id"; then
                    # claim_bead() does: bd update --claim + dolt push + ipc_signal_pushed
                    log "Bead $bead_id already claimed in DB — skipping."
                    bead_id=""
                else
                    # Broadcast claim via IPC so other single-run panes starting up
                    # at the same time skip this bead without waiting for dolt push.
                    ipc_signal_claimed "$bead_id"
                fi
            fi
        fi
    fi

    if [[ -z "$bead_id" ]]; then
        log "No ready beads found. Run 'bd ready' to check status."
        exit 0
    fi

    run_one_bead "$bead_id"
    ipc_clear_claim "$bead_id"
    # Only emit EXIT when running standalone; loop children skip this because
    # run_loop() emits a single EXIT after all iterations complete.
    [[ "${ABR_LOOP_CHILD:-}" != "1" ]] && ipc_event "EXIT" "Worker done (single-bead mode)"
}

main "$@"
